{"pageNumber":532,"ayahs":[{"verseKey":"55:19","surah":55,"ayah":19,"text":"مَرَجَ الْبَحْرَيْنِ يَلْتَقِيَانِ"},{"verseKey":"55:20","surah":55,"ayah":20,"text":"بَيْنَهُمَا بَرْزَخٌ لَا يَبْغِيَانِ"},{"verseKey":"55:21","surah":55,"ayah":21,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:22","surah":55,"ayah":22,"text":"يَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَالْمَرْجَانُ"},{"verseKey":"55:23","surah":55,"ayah":23,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:24","surah":55,"ayah":24,"text":"وَلَهُ الْجَوَارِ الْمُنْشَآتُ فِي الْبَحْرِ كَالْأَعْلَامِ"},{"verseKey":"55:25","surah":55,"ayah":25,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:26","surah":55,"ayah":26,"text":"كُلُّ مَنْ عَلَيْهَا فَانٍ"},{"verseKey":"55:27","surah":55,"ayah":27,"text":"وَيَبْقَىٰ وَجْهُ رَبِّكَ ذُو الْجَلَالِ وَالْإِكْرَامِ"},{"verseKey":"55:28","surah":55,"ayah":28,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:29","surah":55,"ayah":29,"text":"يَسْأَلُهُ مَنْ فِي السَّمَاوَاتِ وَالْأَرْضِ ۚ كُلَّ يَوْمٍ هُوَ فِي شَأْنٍ"},{"verseKey":"55:30","surah":55,"ayah":30,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:31","surah":55,"ayah":31,"text":"سَنَفْرُغُ لَكُمْ أَيُّهَ الثَّقَلَانِ"},{"verseKey":"55:32","surah":55,"ayah":32,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:33","surah":55,"ayah":33,"text":"يَا مَعْشَرَ الْجِنِّ وَالْإِنْسِ إِنِ اسْتَطَعْتُمْ أَنْ تَنْفُذُوا مِنْ أَقْطَارِ السَّمَاوَاتِ وَالْأَرْضِ فَانْفُذُوا ۚ لَا تَنْفُذُونَ إِلَّا بِسُلْطَانٍ"},{"verseKey":"55:34","surah":55,"ayah":34,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:35","surah":55,"ayah":35,"text":"يُرْسَلُ عَلَيْكُمَا شُوَاظٌ مِنْ نَارٍ وَنُحَاسٌ فَلَا تَنْتَصِرَانِ"},{"verseKey":"55:36","surah":55,"ayah":36,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:37","surah":55,"ayah":37,"text":"فَإِذَا انْشَقَّتِ السَّمَاءُ فَكَانَتْ وَرْدَةً كَالدِّهَانِ"},{"verseKey":"55:38","surah":55,"ayah":38,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:39","surah":55,"ayah":39,"text":"فَيَوْمَئِذٍ لَا يُسْأَلُ عَنْ ذَنْبِهِ إِنْسٌ وَلَا جَانٌّ"},{"verseKey":"55:40","surah":55,"ayah":40,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:41","surah":55,"ayah":41,"text":"يُعْرَفُ الْمُجْرِمُونَ بِسِيمَاهُمْ فَيُؤْخَذُ بِالنَّوَاصِي وَالْأَقْدَامِ"}]}

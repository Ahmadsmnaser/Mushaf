{"pageNumber":602,"ayahs":[{"verseKey":"106:1","surah":106,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ لِإِيلَافِ قُرَيْشٍ"},{"verseKey":"106:2","surah":106,"ayah":2,"text":"إِيلَافِهِمْ رِحْلَةَ الشِّتَاءِ وَالصَّيْفِ"},{"verseKey":"106:3","surah":106,"ayah":3,"text":"فَلْيَعْبُدُوا رَبَّ هَٰذَا الْبَيْتِ"},{"verseKey":"106:4","surah":106,"ayah":4,"text":"الَّذِي أَطْعَمَهُمْ مِنْ جُوعٍ وَآمَنَهُمْ مِنْ خَوْفٍ"},{"verseKey":"107:1","surah":107,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ أَرَأَيْتَ الَّذِي يُكَذِّبُ بِالدِّينِ"},{"verseKey":"107:2","surah":107,"ayah":2,"text":"فَذَٰلِكَ الَّذِي يَدُعُّ الْيَتِيمَ"},{"verseKey":"107:3","surah":107,"ayah":3,"text":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ الْمِسْكِينِ"},{"verseKey":"107:4","surah":107,"ayah":4,"text":"فَوَيْلٌ لِلْمُصَلِّينَ"},{"verseKey":"107:5","surah":107,"ayah":5,"text":"الَّذِينَ هُمْ عَنْ صَلَاتِهِمْ سَاهُونَ"},{"verseKey":"107:6","surah":107,"ayah":6,"text":"الَّذِينَ هُمْ يُرَاءُونَ"},{"verseKey":"107:7","surah":107,"ayah":7,"text":"وَيَمْنَعُونَ الْمَاعُونَ"},{"verseKey":"108:1","surah":108,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ إِنَّا أَعْطَيْنَاكَ الْكَوْثَرَ"},{"verseKey":"108:2","surah":108,"ayah":2,"text":"فَصَلِّ لِرَبِّكَ وَانْحَرْ"},{"verseKey":"108:3","surah":108,"ayah":3,"text":"إِنَّ شَانِئَكَ هُوَ الْأَبْتَرُ"}]}

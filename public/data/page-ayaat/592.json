{"pageNumber":592,"ayahs":[{"verseKey":"87:11","surah":87,"ayah":11,"text":"وَيَتَجَنَّبُهَا الْأَشْقَى"},{"verseKey":"87:12","surah":87,"ayah":12,"text":"الَّذِي يَصْلَى النَّارَ الْكُبْرَىٰ"},{"verseKey":"87:13","surah":87,"ayah":13,"text":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ"},{"verseKey":"87:14","surah":87,"ayah":14,"text":"قَدْ أَفْلَحَ مَنْ تَزَكَّىٰ"},{"verseKey":"87:15","surah":87,"ayah":15,"text":"وَذَكَرَ اسْمَ رَبِّهِ فَصَلَّىٰ"},{"verseKey":"87:16","surah":87,"ayah":16,"text":"بَلْ تُؤْثِرُونَ الْحَيَاةَ الدُّنْيَا"},{"verseKey":"87:17","surah":87,"ayah":17,"text":"وَالْآخِرَةُ خَيْرٌ وَأَبْقَىٰ"},{"verseKey":"87:18","surah":87,"ayah":18,"text":"إِنَّ هَٰذَا لَفِي الصُّحُفِ الْأُولَىٰ"},{"verseKey":"87:19","surah":87,"ayah":19,"text":"صُحُفِ إِبْرَاهِيمَ وَمُوسَىٰ"},{"verseKey":"88:1","surah":88,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ هَلْ أَتَاكَ حَدِيثُ الْغَاشِيَةِ"},{"verseKey":"88:2","surah":88,"ayah":2,"text":"وُجُوهٌ يَوْمَئِذٍ خَاشِعَةٌ"},{"verseKey":"88:3","surah":88,"ayah":3,"text":"عَامِلَةٌ نَاصِبَةٌ"},{"verseKey":"88:4","surah":88,"ayah":4,"text":"تَصْلَىٰ نَارًا حَامِيَةً"},{"verseKey":"88:5","surah":88,"ayah":5,"text":"تُسْقَىٰ مِنْ عَيْنٍ آنِيَةٍ"},{"verseKey":"88:6","surah":88,"ayah":6,"text":"لَيْسَ لَهُمْ طَعَامٌ إِلَّا مِنْ ضَرِيعٍ"},{"verseKey":"88:7","surah":88,"ayah":7,"text":"لَا يُسْمِنُ وَلَا يُغْنِي مِنْ جُوعٍ"},{"verseKey":"88:8","surah":88,"ayah":8,"text":"وُجُوهٌ يَوْمَئِذٍ نَاعِمَةٌ"},{"verseKey":"88:9","surah":88,"ayah":9,"text":"لِسَعْيِهَا رَاضِيَةٌ"},{"verseKey":"88:10","surah":88,"ayah":10,"text":"فِي جَنَّةٍ عَالِيَةٍ"},{"verseKey":"88:11","surah":88,"ayah":11,"text":"لَا تَسْمَعُ فِيهَا لَاغِيَةً"},{"verseKey":"88:12","surah":88,"ayah":12,"text":"فِيهَا عَيْنٌ جَارِيَةٌ"},{"verseKey":"88:13","surah":88,"ayah":13,"text":"فِيهَا سُرُرٌ مَرْفُوعَةٌ"},{"verseKey":"88:14","surah":88,"ayah":14,"text":"وَأَكْوَابٌ مَوْضُوعَةٌ"},{"verseKey":"88:15","surah":88,"ayah":15,"text":"وَنَمَارِقُ مَصْفُوفَةٌ"},{"
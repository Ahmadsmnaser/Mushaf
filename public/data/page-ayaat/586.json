{"pageNumber":586,"ayahs":[{"verseKey":"80:41","surah":80,"ayah":41,"text":"تَرْهَقُهَا قَتَرَةٌ"},{"verseKey":"80:42","surah":80,"ayah":42,"text":"أُولَٰئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ"},{"verseKey":"81:1","surah":81,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ إِذَا الشَّمْسُ كُوِّرَتْ"},{"verseKey":"81:2","surah":81,"ayah":2,"text":"وَإِذَا النُّجُومُ انْكَدَرَتْ"},{"verseKey":"81:3","surah":81,"ayah":3,"text":"وَإِذَا الْجِبَالُ سُيِّرَتْ"},{"verseKey":"81:4","surah":81,"ayah":4,"text":"وَإِذَا الْعِشَارُ عُطِّلَتْ"},{"verseKey":"81:5","surah":81,"ayah":5,"text":"وَإِذَا الْوُحُوشُ حُشِرَتْ"},{"verseKey":"81:6","surah":81,"ayah":6,"text":"وَإِذَا الْبِحَارُ سُجِّرَتْ"},{"verseKey":"81:7","surah":81,"ayah":7,"text":"وَإِذَا النُّفُوسُ زُوِّجَتْ"},{"verseKey":"81:8","surah":81,"ayah":8,"text":"وَإِذَا الْمَوْءُودَةُ سُئِلَتْ"},{"verseKey":"81:9","surah":81,"ayah":9,"text":"بِأَيِّ ذَنْبٍ قُتِلَتْ"},{"verseKey":"81:10","surah":81,"ayah":10,"text":"وَإِذَا الصُّحُفُ نُشِرَتْ"},{"verseKey":"81:11","surah":81,"ayah":11,"text":"وَإِذَا السَّمَاءُ كُشِطَتْ"},{"verseKey":"81:12","surah":81,"ayah":12,"text":"وَإِذَا الْجَحِيمُ سُعِّرَتْ"},{"verseKey":"81:13","surah":81,"ayah":13,"text":"وَإِذَا الْجَنَّةُ أُزْلِفَتْ"},{"verseKey":"81:14","surah":81,"ayah":14,"text":"عَلِمَتْ نَفْسٌ مَا أَحْضَرَتْ"},{"verseKey":"81:15","surah":81,"ayah":15,"text":"فَلَا أُقْسِمُ بِالْخُنَّسِ"},{"verseKey":"81:16","surah":81,"ayah":16,"text":"الْجَوَارِ الْكُنَّسِ"},{"verseKey":"81:17","surah":81,"ayah":17,"text":"وَاللَّيْلِ إِذَا عَسْعَسَ"},{"verseKey":"81:18","surah":81,"ayah":18,"text":"وَالصُّبْحِ إِذَا تَنَفَّسَ"},{"verseKey":"81:19","surah":81,"ayah":19,"text":"إِنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ"},{"verseKey":"81:20","surah":81,"ayah":20,"text":"ذِي قُوَّةٍ عِنْدَ ذِي الْعَرْشِ مَكِينٍ"},{"verseKey":"81:21","surah":81,"ayah":21,"text":"مُطَاعٍ ثَمَّ أَمِينٍ"},{"verseKey":"81:22","surah":81,"ayah":22,"text":"وَمَا صَاحِبُكُمْ بِمَجْنُونٍ"},{"verseKey":"81:23","surah":81,"ayah":23,"text":"وَلَقَدْ رَآهُ بِالْأُفُقِ الْمُبِينِ"},{"verseKey":"81:24","surah":81,"ayah":24,"text":"وَمَا هُوَ عَلَى الْغَيْبِ بِضَنِينٍ"},{"verseKey":"81:25","surah":81,"ayah":25,"text":"وَمَا هُوَ بِقَوْلِ شَيْطَانٍ رَجِيمٍ"},{"verseKey":"81:26","surah":81,"ayah":26,"text":"فَأَيْنَ تَذْهَبُونَ"},{"verseKey":"81:27","surah":81,"ayah":27,"text":"إِنْ هُوَ إِلَّا ذِكْرٌ لِلْعَالَمِينَ"},{"verseKey":"81:28","surah":81,"ayah":28,"text":"لِمَنْ شَاءَ مِنْكُمْ أَنْ يَسْتَقِيمَ"},{"verseKey":"81:29","surah":81,"ayah":29,"text":"وَمَا تَشَاءُونَ إِلَّا أَنْ يَشَاءَ اللَّهُ رَبُّ الْعَالَمِينَ"}]}

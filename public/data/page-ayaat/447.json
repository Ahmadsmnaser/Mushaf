{"pageNumber":447,"ayahs":[{"verseKey":"37:25","surah":37,"ayah":25,"text":"مَا لَكُمْ لَا تَنَاصَرُونَ"},{"verseKey":"37:26","surah":37,"ayah":26,"text":"بَلْ هُمُ الْيَوْمَ مُسْتَسْلِمُونَ"},{"verseKey":"37:27","surah":37,"ayah":27,"text":"وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَاءَلُونَ"},{"verseKey":"37:28","surah":37,"ayah":28,"text":"قَالُوا إِنَّكُمْ كُنْتُمْ تَأْتُونَنَا عَنِ الْيَمِينِ"},{"verseKey":"37:29","surah":37,"ayah":29,"text":"قَالُوا بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ"},{"verseKey":"37:30","surah":37,"ayah":30,"text":"وَمَا كَانَ لَنَا عَلَيْكُمْ مِنْ سُلْطَانٍ ۖ بَلْ كُنْتُمْ قَوْمًا طَاغِينَ"},{"verseKey":"37:31","surah":37,"ayah":31,"text":"فَحَقَّ عَلَيْنَا قَوْلُ رَبِّنَا ۖ إِنَّا لَذَائِقُونَ"},{"verseKey":"37:32","surah":37,"ayah":32,"text":"فَأَغْوَيْنَاكُمْ إِنَّا كُنَّا غَاوِينَ"},{"verseKey":"37:33","surah":37,"ayah":33,"text":"فَإِنَّهُمْ يَوْمَئِذٍ فِي الْعَذَابِ مُشْتَرِكُونَ"},{"verseKey":"37:34","surah":37,"ayah":34,"text":"إِنَّا كَذَٰلِكَ نَفْعَلُ بِالْمُجْرِمِينَ"},{"verseKey":"37:35","surah":37,"ayah":35,"text":"إِنَّهُمْ كَانُوا إِذَا قِيلَ لَهُمْ لَا إِلَٰهَ إِلَّا اللَّهُ يَسْتَكْبِرُونَ"},{"verseKey":"37:36","surah":37,"ayah":36,"text":"وَيَقُولُونَ أَئِنَّا لَتَارِكُو آلِهَتِنَا لِشَاعِرٍ مَجْنُونٍ"},{"verseKey":"37:37","surah":37,"ayah":37,"text":"بَلْ جَاءَ بِالْحَقِّ وَصَدَّقَ الْمُرْسَلِينَ"},{"verseKey":"37:38","surah":37,"ayah":38,"text":"إِنَّكُمْ لَذَائِقُو الْعَذَابِ الْأَلِيمِ"},{"verseKey":"37:39","surah":37,"ayah":39,"text":"وَمَا تُجْزَوْنَ إِلَّا مَا كُنْتُمْ تَعْمَلُونَ"},{"verseKey":"37:40","surah":37,"ayah":40,"text":"إِلَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ"},{"verseKey":"37:41","surah":37,"ayah":41,"text":"أُولَٰئِكَ لَهُمْ رِزْقٌ مَعْلُومٌ"},{"verseKey":"37:42","surah":37,"ayah":42,"text":"فَوَاكِهُ ۖ وَهُمْ مُكْرَمُونَ"},{"verseKey":"37:43","surah":37,"ayah":43,"text":"فِي جَنَّاتِ النَّعِيمِ"},{"verseKey":"37:44","surah":37,"ayah":44,"text":"عَلَىٰ سُرُرٍ مُتَقَابِلِينَ"},{"verseKey":"37:45","surah":37,"ayah":45,"text":"يُطَافُ عَلَيْهِمْ بِكَأْسٍ مِنْ مَعِينٍ"},{"verseKey":"37:46","surah":37,"ayah":46,"text":"بَيْضَاءَ لَذَّةٍ لِلشَّارِبِينَ"},{"verseKey":"37:47","surah":37,"ayah":47,"text":"لَا فِيهَا غَوْلٌ وَلَا هُمْ عَنْهَا يُنْزَفُونَ"},{"verseKey":"37:48","surah":37,"ayah":48,"text":"وَعِنْدَهُمْ قَاصِرَاتُ الطَّرْفِ عِينٌ"},{"verseKey":"37:49","surah":37,"ayah":49,"text":"كَأَنَّهُنَّ بَيْضٌ مَكْنُونٌ"},{"verseKey":"37:50","surah":37,"ayah":50,"text":"فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَاءَلُونَ"},{"verseKey":"37:51","surah":37,"ayah":51,"text":"قَالَ قَائِلٌ مِنْهُمْ إِنِّي كَانَ لِي قَرِينٌ"}]}

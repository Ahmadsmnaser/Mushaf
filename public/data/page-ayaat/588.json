{"pageNumber":588,"ayahs":[{"verseKey":"83:5","surah":83,"ayah":5,"text":"لِيَوْمٍ عَظِيمٍ"},{"verseKey":"83:6","surah":83,"ayah":6,"text":"يَوْمَ يَقُومُ النَّاسُ لِرَبِّ الْعَالَمِينَ"},{"verseKey":"83:7","surah":83,"ayah":7,"text":"كَلَّا إِنَّ كِتَابَ الْفُجَّارِ لَفِي سِجِّينٍ"},{"verseKey":"83:8","surah":83,"ayah":8,"text":"وَمَا أَدْرَاكَ مَا سِجِّينٌ"},{"verseKey":"83:9","surah":83,"ayah":9,"text":"كِتَابٌ مَرْقُومٌ"},{"verseKey":"83:10","surah":83,"ayah":10,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"83:11","surah":83,"ayah":11,"text":"الَّذِينَ يُكَذِّبُونَ بِيَوْمِ الدِّينِ"},{"verseKey":"83:12","surah":83,"ayah":12,"text":"وَمَا يُكَذِّبُ بِهِ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ"},{"verseKey":"83:13","surah":83,"ayah":13,"text":"إِذَا تُتْلَىٰ عَلَيْهِ آيَاتُنَا قَالَ أَسَاطِيرُ الْأَوَّلِينَ"},{"verseKey":"83:14","surah":83,"ayah":14,"text":"كَلَّا ۖ بَلْ ۜ رَانَ عَلَىٰ قُلُوبِهِمْ مَا كَانُوا يَكْسِبُونَ"},{"verseKey":"83:15","surah":83,"ayah":15,"text":"كَلَّا إِنَّهُمْ عَنْ رَبِّهِمْ يَوْمَئِذٍ لَمَحْجُوبُونَ"},{"verseKey":"83:16","surah":83,"ayah":16,"text":"ثُمَّ إِنَّهُمْ لَصَالُو الْجَحِيمِ"},{"verseKey":"83:17","surah":83,"ayah":17,"text":"ثُمَّ يُقَالُ هَٰذَا الَّذِي كُنْتُمْ بِهِ تُكَذِّبُونَ"},{"verseKey":"83:18","surah":83,"ayah":18,"text":"كَلَّا إِنَّ كِتَابَ الْأَبْرَارِ لَفِي عِلِّيِّينَ"},{"verseKey":"83:19","surah":83,"ayah":19,"text":"وَمَا أَدْرَاكَ مَا عِلِّيُّونَ"},{"verseKey":"83:20","surah":83,"ayah":20,"text":"كِتَابٌ مَرْقُومٌ"},{"verseKey":"83:21","surah":83,"ayah":21,"text":"يَشْهَدُهُ الْمُقَرَّبُونَ"},{"verseKey":"83:22","surah":83,"ayah":22,"text":"إِنَّ الْأَبْرَارَ لَفِي نَعِيمٍ"},{"verseKey":"83:23","surah":83,"ayah":23,"text":"عَلَى الْأَرَائِكِ يَنْظُرُونَ"},{"verseKey":"83:24","surah":83,"ayah":24,"text":"تَعْرِفُ فِي وُجُوهِهِمْ نَضْرَةَ النَّعِيمِ"},{"verseKey":"83:25","surah":83,"ayah":25,"text":"يُسْقَوْنَ مِنْ رَحِيقٍ مَخْتُومٍ"},{"verseKey":"83:26","surah":83,"ayah":26,"text":"خِتَامُهُ مِسْكٌ ۚ وَفِي ذَٰلِكَ فَلْيَتَنَافَسِ الْمُتَنَافِسُونَ"},{"verseKey":"83:27","surah":83,"ayah":27,"text":"وَمِزَاجُهُ مِنْ تَسْنِيمٍ"},{"verseKey":"83:28","surah":83,"ayah":28,"text":"عَيْنًا يَشْرَبُ بِهَا الْمُقَرَّبُونَ"},{"verseKey":"83:29","surah":83,"ayah":29,"text":"إِنَّ الَّذِينَ أَجْرَمُوا كَانُوا مِنَ الَّذِينَ آمَنُوا يَضْحَكُونَ"},{"verseKey":"83:30","surah":83,"ayah":30,"text":"وَإِذَا مَرُّوا بِهِمْ يَتَغَامَزُونَ"},{"verseKey":"83:31","surah":83,"ayah":31,"text":"وَإِذَا انْقَلَبُوا إِلَىٰ أَهْلِهِمُ انْقَلَبُوا فَكِهِينَ"},{"verseKey":"83:32","surah":83,"ayah":32,"text":"وَإِذَا رَأَوْهُمْ قَالُوا إِنَّ هَٰؤُلَاءِ لَضَالُّونَ"},{"verseKey":"83:33","surah":83,"ayah":33,"text":"وَمَا أُرْسِلُوا عَلَيْهِمْ حَافِظِينَ"}]}

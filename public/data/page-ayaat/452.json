{"pageNumber":452,"ayahs":[{"verseKey":"37:154","surah":37,"ayah":154,"text":"مَا لَكُمْ كَيْفَ تَحْكُمُونَ"},{"verseKey":"37:155","surah":37,"ayah":155,"text":"أَفَلَا تَذَكَّرُونَ"},{"verseKey":"37:156","surah":37,"ayah":156,"text":"أَمْ لَكُمْ سُلْطَانٌ مُبِينٌ"},{"verseKey":"37:157","surah":37,"ayah":157,"text":"فَأْتُوا بِكِتَابِكُمْ إِنْ كُنْتُمْ صَادِقِينَ"},{"verseKey":"37:158","surah":37,"ayah":158,"text":"وَجَعَلُوا بَيْنَهُ وَبَيْنَ الْجِنَّةِ نَسَبًا ۚ وَلَقَدْ عَلِمَتِ الْجِنَّةُ إِنَّهُمْ لَمُحْضَرُونَ"},{"verseKey":"37:159","surah":37,"ayah":159,"text":"سُبْحَانَ اللَّهِ عَمَّا يَصِفُونَ"},{"verseKey":"37:160","surah":37,"ayah":160,"text":"إِلَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ"},{"verseKey":"37:161","surah":37,"ayah":161,"text":"فَإِنَّكُمْ وَمَا تَعْبُدُونَ"},{"verseKey":"37:162","surah":37,"ayah":162,"text":"مَا أَنْتُمْ عَلَيْهِ بِفَاتِنِينَ"},{"verseKey":"37:163","surah":37,"ayah":163,"text":"إِلَّا مَنْ هُوَ صَالِ الْجَحِيمِ"},{"verseKey":"37:164","surah":37,"ayah":164,"text":"وَمَا مِنَّا إِلَّا لَهُ مَقَامٌ مَعْلُومٌ"},{"verseKey":"37:165","surah":37,"ayah":165,"text":"وَإِنَّا لَنَحْنُ الصَّافُّونَ"},{"verseKey":"37:166","surah":37,"ayah":166,"text":"وَإِنَّا لَنَحْنُ الْمُسَبِّحُونَ"},{"verseKey":"37:167","surah":37,"ayah":167,"text":"وَإِنْ كَانُوا لَيَقُولُونَ"},{"verseKey":"37:168","surah":37,"ayah":168,"text":"لَوْ أَنَّ عِنْدَنَا ذِكْرًا مِنَ الْأَوَّلِينَ"},{"verseKey":"37:169","surah":37,"ayah":169,"text":"لَكُنَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ"},{"verseKey":"37:170","surah":37,"ayah":170,"text":"فَكَفَرُوا بِهِ ۖ فَسَوْفَ يَعْلَمُونَ"},{"verseKey":"37:171","surah":37,"ayah":171,"text":"وَلَقَدْ سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا الْمُرْسَلِينَ"},{"verseKey":"37:172","surah":37,"ayah":172,"text":"إِنَّهُمْ لَهُمُ الْمَنْصُورُونَ"},{"verseKey":"37:173","surah":37,"ayah":173,"text":"وَإِنَّ جُنْدَنَا لَهُمُ الْغَالِبُونَ"},{"verseKey":"37:174","surah":37,"ayah":174,"text":"فَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍ"},{"verseKey":"37:175","surah":37,"ayah":175,"text":"وَأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ"},{"verseKey":"37:176","surah":37,"ayah":176,"text":"أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ"},{"verseKey":"37:177","surah":37,"ayah":177,"text":"فَإِذَا نَزَلَ بِسَاحَتِهِمْ فَسَاءَ صَبَاحُ الْمُنْذَرِينَ"},{"verseKey":"37:178","surah":37,"ayah":178,"text":"وَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍ"},{"verseKey":"37:179","surah":37,"ayah":179,"text":"وَأَبْصِرْ فَسَوْفَ يُبْصِرُونَ"},{"verseKey":"37:180","surah":37,"ayah":180,"text":"سُبْحَانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمَّا يَصِفُونَ"},{"verseKey":"37:181","surah":37,"ayah":181,"text":"وَسَلَامٌ عَلَى الْمُرْسَلِينَ"},{"verseKey":"37:182","surah":37,"ayah":182,"text":"وَالْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ"}]}

{"pageNumber":448,"ayahs":[{"verseKey":"37:52","surah":37,"ayah":52,"text":"يَقُولُ أَإِنَّكَ لَمِنَ الْمُصَدِّقِينَ"},{"verseKey":"37:53","surah":37,"ayah":53,"text":"أَإِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَامًا أَإِنَّا لَمَدِينُونَ"},{"verseKey":"37:54","surah":37,"ayah":54,"text":"قَالَ هَلْ أَنْتُمْ مُطَّلِعُونَ"},{"verseKey":"37:55","surah":37,"ayah":55,"text":"فَاطَّلَعَ فَرَآهُ فِي سَوَاءِ الْجَحِيمِ"},{"verseKey":"37:56","surah":37,"ayah":56,"text":"قَالَ تَاللَّهِ إِنْ كِدْتَ لَتُرْدِينِ"},{"verseKey":"37:57","surah":37,"ayah":57,"text":"وَلَوْلَا نِعْمَةُ رَبِّي لَكُنْتُ مِنَ الْمُحْضَرِينَ"},{"verseKey":"37:58","surah":37,"ayah":58,"text":"أَفَمَا نَحْنُ بِمَيِّتِينَ"},{"verseKey":"37:59","surah":37,"ayah":59,"text":"إِلَّا مَوْتَتَنَا الْأُولَىٰ وَمَا نَحْنُ بِمُعَذَّبِينَ"},{"verseKey":"37:60","surah":37,"ayah":60,"text":"إِنَّ هَٰذَا لَهُوَ الْفَوْزُ الْعَظِيمُ"},{"verseKey":"37:61","surah":37,"ayah":61,"text":"لِمِثْلِ هَٰذَا فَلْيَعْمَلِ الْعَامِلُونَ"},{"verseKey":"37:62","surah":37,"ayah":62,"text":"أَذَٰلِكَ خَيْرٌ نُزُلًا أَمْ شَجَرَةُ الزَّقُّومِ"},{"verseKey":"37:63","surah":37,"ayah":63,"text":"إِنَّا جَعَلْنَاهَا فِتْنَةً لِلظَّالِمِينَ"},{"verseKey":"37:64","surah":37,"ayah":64,"text":"إِنَّهَا شَجَرَةٌ تَخْرُجُ فِي أَصْلِ الْجَحِيمِ"},{"verseKey":"37:65","surah":37,"ayah":65,"text":"طَلْعُهَا كَأَنَّهُ رُءُوسُ الشَّيَاطِينِ"},{"verseKey":"37:66","surah":37,"ayah":66,"text":"فَإِنَّهُمْ لَآكِلُونَ مِنْهَا فَمَالِئُونَ مِنْهَا الْبُطُونَ"},{"verseKey":"37:67","surah":37,"ayah":67,"text":"ثُمَّ إِنَّ لَهُمْ عَلَيْهَا لَشَوْبًا مِنْ حَمِيمٍ"},{"verseKey":"37:68","surah":37,"ayah":68,"text":"ثُمَّ إِنَّ مَرْجِعَهُمْ لَإِلَى الْجَحِيمِ"},{"verseKey":"37:69","surah":37,"ayah":69,"text":"إِنَّهُمْ أَلْفَوْا آبَاءَهُمْ ضَالِّينَ"},{"verseKey":"37:70","surah":37,"ayah":70,"text":"فَهُمْ عَلَىٰ آثَارِهِمْ يُهْرَعُونَ"},{"verseKey":"37:71","surah":37,"ayah":71,"text":"وَلَقَدْ ضَلَّ قَبْلَهُمْ أَكْثَرُ الْأَوَّلِينَ"},{"verseKey":"37:72","surah":37,"ayah":72,"text":"وَلَقَدْ أَرْسَلْنَا فِيهِمْ مُنْذِرِينَ"},{"verseKey":"37:73","surah":37,"ayah":73,"text":"فَانْظُرْ كَيْفَ كَانَ عَاقِبَةُ الْمُنْذَرِينَ"},{"verseKey":"37:74","surah":37,"ayah":74,"text":"إِلَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ"},{"verseKey":"37:75","surah":37,"ayah":75,"text":"وَلَقَدْ نَادَانَا نُوحٌ فَلَنِعْمَ الْمُجِيبُونَ"},{"verseKey":"37:76","surah":37,"ayah":76,"text":"وَنَجَّيْنَاهُ وَأَهْلَهُ مِنَ الْكَرْبِ الْعَظِيمِ"}]}

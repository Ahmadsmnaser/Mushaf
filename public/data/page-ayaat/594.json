{"pageNumber":594,"ayahs":[{"verseKey":"89:23","surah":89,"ayah":23,"text":"وَجِيءَ يَوْمَئِذٍ بِجَهَنَّمَ ۚ يَوْمَئِذٍ يَتَذَكَّرُ الْإِنْسَانُ وَأَنَّىٰ لَهُ الذِّكْرَىٰ"},{"verseKey":"89:24","surah":89,"ayah":24,"text":"يَقُولُ يَا لَيْتَنِي قَدَّمْتُ لِحَيَاتِي"},{"verseKey":"89:25","surah":89,"ayah":25,"text":"فَيَوْمَئِذٍ لَا يُعَذِّبُ عَذَابَهُ أَحَدٌ"},{"verseKey":"89:26","surah":89,"ayah":26,"text":"وَلَا يُوثِقُ وَثَاقَهُ أَحَدٌ"},{"verseKey":"89:27","surah":89,"ayah":27,"text":"يَا أَيَّتُهَا النَّفْسُ الْمُطْمَئِنَّةُ"},{"verseKey":"89:28","surah":89,"ayah":28,"text":"ارْجِعِي إِلَىٰ رَبِّكِ رَاضِيَةً مَرْضِيَّةً"},{"verseKey":"89:29","surah":89,"ayah":29,"text":"فَادْخُلِي فِي عِبَادِي"},{"verseKey":"89:30","surah":89,"ayah":30,"text":"وَادْخُلِي جَنَّتِي"},{"verseKey":"90:1","surah":90,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ لَا أُقْسِمُ بِهَٰذَا الْبَلَدِ"},{"verseKey":"90:2","surah":90,"ayah":2,"text":"وَأَنْتَ حِلٌّ بِهَٰذَا الْبَلَدِ"},{"verseKey":"90:3","surah":90,"ayah":3,"text":"وَوَالِدٍ وَمَا وَلَدَ"},{"verseKey":"90:4","surah":90,"ayah":4,"text":"لَقَدْ خَلَقْنَا الْإِنْسَانَ فِي كَبَدٍ"},{"verseKey":"90:5","surah":90,"ayah":5,"text":"أَيَحْسَبُ أَنْ لَنْ يَقْدِرَ عَلَيْهِ أَحَدٌ"},{"verseKey":"90:6","surah":90,"ayah":6,"text":"يَقُولُ أَهْلَكْتُ مَالًا لُبَدًا"},{"verseKey":"90:7","surah":90,"ayah":7,"text":"أَيَحْسَبُ أَنْ لَمْ يَرَهُ أَحَدٌ"},{"verseKey":"90:8","surah":90,"ayah":8,"text":"أَلَمْ نَجْعَلْ لَهُ عَيْنَيْنِ"},{"verseKey":"90:9","surah":90,"ayah":9,"text":"وَلِسَانًا وَشَفَتَيْنِ"},{"verseKey":"90:10","surah":90,"ayah":10,"text":"وَهَدَيْنَاهُ النَّجْدَيْنِ"},{"verseKey":"90:11","surah":90,"ayah":11,"text":"فَلَا اقْتَحَمَ الْعَقَبَةَ"},{"verseKey":"90:12","surah":90,"ayah":12,"text":"وَمَا أَدْرَاكَ مَا الْعَقَبَةُ"},{"verseKey":"90:13","surah":90,"ayah":13,"text":"فَكُّ رَقَبَةٍ"},{"verseKey":"90:14","surah":90,"ayah":14,"text":"أَوْ إِطْعَامٌ فِي يَوْمٍ ذِي مَسْغَبَةٍ"},{"verseKey":"90:15","surah":90,"ayah":15,"text":"يَتِيمًا ذَا مَقْرَبَةٍ"},{"verseKey":"90:16","surah":90,"ayah":16,"text":"أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ"},{"verseKey":"90:17","surah":90,"ayah":17,"text":"ثُمَّ كَانَ مِنَ الَّذِينَ آمَنُوا وَتَوَاصَوْا بِالصَّبْرِ وَتَوَاصَوْا بِالْمَرْحَمَةِ"},{"verseKey":"90:18","surah":90,"ayah":18,"text":"أُولَٰئِكَ أَصْحَابُ الْمَيْمَنَةِ"}]}

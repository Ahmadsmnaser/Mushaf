{"pageNumber":528,"ayahs":[{"verseKey":"53:45","surah":53,"ayah":45,"text":"وَأَنَّهُ خَلَقَ الزَّوْجَيْنِ الذَّكَرَ وَالْأُنْثَىٰ"},{"verseKey":"53:46","surah":53,"ayah":46,"text":"مِنْ نُطْفَةٍ إِذَا تُمْنَىٰ"},{"verseKey":"53:47","surah":53,"ayah":47,"text":"وَأَنَّ عَلَيْهِ النَّشْأَةَ الْأُخْرَىٰ"},{"verseKey":"53:48","surah":53,"ayah":48,"text":"وَأَنَّهُ هُوَ أَغْنَىٰ وَأَقْنَىٰ"},{"verseKey":"53:49","surah":53,"ayah":49,"text":"وَأَنَّهُ هُوَ رَبُّ الشِّعْرَىٰ"},{"verseKey":"53:50","surah":53,"ayah":50,"text":"وَأَنَّهُ أَهْلَكَ عَادًا الْأُولَىٰ"},{"verseKey":"53:51","surah":53,"ayah":51,"text":"وَثَمُودَ فَمَا أَبْقَىٰ"},{"verseKey":"53:52","surah":53,"ayah":52,"text":"وَقَوْمَ نُوحٍ مِنْ قَبْلُ ۖ إِنَّهُمْ كَانُوا هُمْ أَظْلَمَ وَأَطْغَىٰ"},{"verseKey":"53:53","surah":53,"ayah":53,"text":"وَالْمُؤْتَفِكَةَ أَهْوَىٰ"},{"verseKey":"53:54","surah":53,"ayah":54,"text":"فَغَشَّاهَا مَا غَشَّىٰ"},{"verseKey":"53:55","surah":53,"ayah":55,"text":"فَبِأَيِّ آلَاءِ رَبِّكَ تَتَمَارَىٰ"},{"verseKey":"53:56","surah":53,"ayah":56,"text":"هَٰذَا نَذِيرٌ مِنَ النُّذُرِ الْأُولَىٰ"},{"verseKey":"53:57","surah":53,"ayah":57,"text":"أَزِفَتِ الْآزِفَةُ"},{"verseKey":"53:58","surah":53,"ayah":58,"text":"لَيْسَ لَهَا مِنْ دُونِ اللَّهِ كَاشِفَةٌ"},{"verseKey":"53:59","surah":53,"ayah":59,"text":"أَفَمِنْ هَٰذَا الْحَدِيثِ تَعْجَبُونَ"},{"verseKey":"53:60","surah":53,"ayah":60,"text":"وَتَضْحَكُونَ وَلَا تَبْكُونَ"},{"verseKey":"53:61","surah":53,"ayah":61,"text":"وَأَنْتُمْ سَامِدُونَ"},{"verseKey":"53:62","surah":53,"ayah":62,"text":"فَاسْجُدُوا لِلَّهِ وَاعْبُدُوا ۩"},{"verseKey":"54:1","surah":54,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ اقْتَرَبَتِ السَّاعَةُ وَانْشَقَّ الْقَمَرُ"},{"verseKey":"54:2","surah":54,"ayah":2,"text":"وَإِنْ يَرَوْا آيَةً يُعْرِضُوا وَيَقُولُوا سِحْرٌ مُسْتَمِرٌّ"},{"verseKey":"54:3","surah":54,"ayah":3,"text":"وَكَذَّبُوا وَاتَّبَعُوا أَهْوَاءَهُمْ ۚ وَكُلُّ أَمْرٍ مُسْتَقِرٌّ"},{"verseKey":"54:4","surah":54,"ayah":4,"text":"وَلَقَدْ جَاءَهُمْ مِنَ الْأَنْبَاءِ مَا فِيهِ مُزْدَجَرٌ"},{"verseKey":"54:5","surah":54,"ayah":5,"text":"حِكْمَةٌ بَالِغَةٌ ۖ فَمَا تُغْنِ النُّذُرُ"},{"verseKey":"54:6","surah":54,"ayah":6,"text":"فَتَوَلَّ عَنْهُمْ ۘ يَوْمَ يَدْعُ الدَّاعِ إِلَىٰ شَيْءٍ نُكُرٍ"}]}

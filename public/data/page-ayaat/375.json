{"pageNumber":375,"ayahs":[{"verseKey":"26:184","surah":26,"ayah":184,"text":"وَاتَّقُوا الَّذِي خَلَقَكُمْ وَالْجِبِلَّةَ الْأَوَّلِينَ"},{"verseKey":"26:185","surah":26,"ayah":185,"text":"قَالُوا إِنَّمَا أَنْتَ مِنَ الْمُسَحَّرِينَ"},{"verseKey":"26:186","surah":26,"ayah":186,"text":"وَمَا أَنْتَ إِلَّا بَشَرٌ مِثْلُنَا وَإِنْ نَظُنُّكَ لَمِنَ الْكَاذِبِينَ"},{"verseKey":"26:187","surah":26,"ayah":187,"text":"فَأَسْقِطْ عَلَيْنَا كِسَفًا مِنَ السَّمَاءِ إِنْ كُنْتَ مِنَ الصَّادِقِينَ"},{"verseKey":"26:188","surah":26,"ayah":188,"text":"قَالَ رَبِّي أَعْلَمُ بِمَا تَعْمَلُونَ"},{"verseKey":"26:189","surah":26,"ayah":189,"text":"فَكَذَّبُوهُ فَأَخَذَهُمْ عَذَابُ يَوْمِ الظُّلَّةِ ۚ إِنَّهُ كَانَ عَذَابَ يَوْمٍ عَظِيمٍ"},{"verseKey":"26:190","surah":26,"ayah":190,"text":"إِنَّ فِي ذَٰلِكَ لَآيَةً ۖ وَمَا كَانَ أَكْثَرُهُمْ مُؤْمِنِينَ"},{"verseKey":"26:191","surah":26,"ayah":191,"text":"وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ الرَّحِيمُ"},{"verseKey":"26:192","surah":26,"ayah":192,"text":"وَإِنَّهُ لَتَنْزِيلُ رَبِّ الْعَالَمِينَ"},{"verseKey":"26:193","surah":26,"ayah":193,"text":"نَزَلَ بِهِ الرُّوحُ الْأَمِينُ"},{"verseKey":"26:194","surah":26,"ayah":194,"text":"عَلَىٰ قَلْبِكَ لِتَكُونَ مِنَ الْمُنْذِرِينَ"},{"verseKey":"26:195","surah":26,"ayah":195,"text":"بِلِسَانٍ عَرَبِيٍّ مُبِينٍ"},{"verseKey":"26:196","surah":26,"ayah":196,"text":"وَإِنَّهُ لَفِي زُبُرِ الْأَوَّلِينَ"},{"verseKey":"26:197","surah":26,"ayah":197,"text":"أَوَلَمْ يَكُنْ لَهُمْ آيَةً أَنْ يَعْلَمَهُ عُلَمَاءُ بَنِي إِسْرَائِيلَ"},{"verseKey":"26:198","surah":26,"ayah":198,"text":"وَلَوْ نَزَّلْنَاهُ عَلَىٰ بَعْضِ الْأَعْجَمِينَ"},{"verseKey":"26:199","surah":26,"ayah":199,"text":"فَقَرَأَهُ عَلَيْهِمْ مَا كَانُوا بِهِ مُؤْمِنِينَ"},{"verseKey":"26:200","surah":26,"ayah":200,"text":"كَذَٰلِكَ سَلَكْنَاهُ فِي قُلُوبِ الْمُجْرِمِينَ"},{"verseKey":"26:201","surah":26,"ayah":201,"text":"لَا يُؤْمِنُونَ بِهِ حَتَّىٰ يَرَوُا الْعَذَابَ الْأَلِيمَ"},{"verseKey":"26:202","surah":26,"ayah":202,"text":"فَيَأْتِيَهُمْ بَغْتَةً وَهُمْ لَا يَشْعُرُونَ"},{"verseKey":"26:203","surah":26,"ayah":203,"text":"فَيَقُولُوا هَلْ نَحْنُ مُنْظَرُونَ"},{"verseKey":"26:204","surah":26,"ayah":204,"text":"أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ"},{"verseKey":"26:205","surah":26,"ayah":205,"text":"أَفَرَأَيْتَ إِنْ مَتَّعْنَاهُمْ سِنِينَ"},{"verseKey":"26:206","surah":26,"ayah":206,"text":"ثُمَّ جَاءَهُمْ مَا كَانُوا يُوعَدُونَ"}]}

{"pageNumber":533,"ayahs":[{"verseKey":"55:42","surah":55,"ayah":42,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:43","surah":55,"ayah":43,"text":"هَٰذِهِ جَهَنَّمُ الَّتِي يُكَذِّبُ بِهَا الْمُجْرِمُونَ"},{"verseKey":"55:44","surah":55,"ayah":44,"text":"يَطُوفُونَ بَيْنَهَا وَبَيْنَ حَمِيمٍ آنٍ"},{"verseKey":"55:45","surah":55,"ayah":45,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:46","surah":55,"ayah":46,"text":"وَلِمَنْ خَافَ مَقَامَ رَبِّهِ جَنَّتَانِ"},{"verseKey":"55:47","surah":55,"ayah":47,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:48","surah":55,"ayah":48,"text":"ذَوَاتَا أَفْنَانٍ"},{"verseKey":"55:49","surah":55,"ayah":49,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:50","surah":55,"ayah":50,"text":"فِيهِمَا عَيْنَانِ تَجْرِيَانِ"},{"verseKey":"55:51","surah":55,"ayah":51,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:52","surah":55,"ayah":52,"text":"فِيهِمَا مِنْ كُلِّ فَاكِهَةٍ زَوْجَانِ"},{"verseKey":"55:53","surah":55,"ayah":53,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:54","surah":55,"ayah":54,"text":"مُتَّكِئِينَ عَلَىٰ فُرُشٍ بَطَائِنُهَا مِنْ إِسْتَبْرَقٍ ۚ وَجَنَى الْجَنَّتَيْنِ دَانٍ"},{"verseKey":"55:55","surah":55,"ayah":55,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:56","surah":55,"ayah":56,"text":"فِيهِنَّ قَاصِرَاتُ الطَّرْفِ لَمْ يَطْمِثْهُنَّ إِنْسٌ قَبْلَهُمْ وَلَا جَانٌّ"},{"verseKey":"55:57","surah":55,"ayah":57,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:58","surah":55,"ayah":58,"text":"كَأَنَّهُنَّ الْيَاقُوتُ وَالْمَرْجَانُ"},{"verseKey":"55:59","surah":55,"ayah":59,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:60","surah":55,"ayah":60,"text":"هَلْ جَزَاءُ الْإِحْسَانِ إِلَّا الْإِحْسَانُ"},{"verseKey":"55:61","surah":55,"ayah":61,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:62","surah":55,"ayah":62,"text":"وَمِنْ دُونِهِمَا جَنَّتَانِ"},{"verseKey":"55:63","surah":55,"ayah":63,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:64","surah":55,"ayah":64,"text":"مُدْهَامَّتَانِ"},{"verseKey":"55:65","surah":55,"ayah":65,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:66","surah":55,"ayah":66,"text":"فِيهِمَا عَيْنَانِ نَضَّاخَتَانِ"},{"verseKey":"55:67","surah":55,"ayah":67,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:68","surah":55,"ayah":68,"text":"فِيهِمَا فَاكِهَةٌ وَنَخْلٌ وَرُمَّانٌ"},{"verseKey":"55:69","surah":55,"ayah":69,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"}]}

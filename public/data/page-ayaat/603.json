{"pageNumber":603,"ayahs":[{"verseKey":"109:1","surah":109,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ قُلْ يَا أَيُّهَا الْكَافِرُونَ"},{"verseKey":"109:2","surah":109,"ayah":2,"text":"لَا أَعْبُدُ مَا تَعْبُدُونَ"},{"verseKey":"109:3","surah":109,"ayah":3,"text":"وَلَا أَنْتُمْ عَابِدُونَ مَا أَعْبُدُ"},{"verseKey":"109:4","surah":109,"ayah":4,"text":"وَلَا أَنَا عَابِدٌ مَا عَبَدْتُمْ"},{"verseKey":"109:5","surah":109,"ayah":5,"text":"وَلَا أَنْتُمْ عَابِدُونَ مَا أَعْبُدُ"},{"verseKey":"109:6","surah":109,"ayah":6,"text":"لَكُمْ دِينُكُمْ وَلِيَ دِينِ"},{"verseKey":"110:1","surah":110,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ إِذَا جَاءَ نَصْرُ اللَّهِ وَالْفَتْحُ"},{"verseKey":"110:2","surah":110,"ayah":2,"text":"وَرَأَيْتَ النَّاسَ يَدْخُلُونَ فِي دِينِ اللَّهِ أَفْوَاجًا"},{"verseKey":"110:3","surah":110,"ayah":3,"text":"فَسَبِّحْ بِحَمْدِ رَبِّكَ وَاسْتَغْفِرْهُ ۚ إِنَّهُ كَانَ تَوَّابًا"},{"verseKey":"111:1","surah":111,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ تَبَّتْ يَدَا أَبِي لَهَبٍ وَتَبَّ"},{"verseKey":"111:2","surah":111,"ayah":2,"text":"مَا أَغْنَىٰ عَنْهُ مَالُهُ وَمَا كَسَبَ"},{"verseKey":"111:3","surah":111,"ayah":3,"text":"سَيَصْلَىٰ نَارًا ذَاتَ لَهَبٍ"},{"verseKey":"111:4","surah":111,"ayah":4,"text":"وَامْرَأَتُهُ حَمَّالَةَ الْحَطَبِ"},{"verseKey":"111:5","surah":111,"ayah":5,"text":"فِي جِيدِهَا حَبْلٌ مِنْ مَسَدٍ"}]}

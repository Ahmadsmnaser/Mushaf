{"pageNumber":534,"ayahs":[{"verseKey":"55:70","surah":55,"ayah":70,"text":"فِيهِنَّ خَيْرَاتٌ حِسَانٌ"},{"verseKey":"55:71","surah":55,"ayah":71,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:72","surah":55,"ayah":72,"text":"حُورٌ مَقْصُورَاتٌ فِي الْخِيَامِ"},{"verseKey":"55:73","surah":55,"ayah":73,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:74","surah":55,"ayah":74,"text":"لَمْ يَطْمِثْهُنَّ إِنْسٌ قَبْلَهُمْ وَلَا جَانٌّ"},{"verseKey":"55:75","surah":55,"ayah":75,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:76","surah":55,"ayah":76,"text":"مُتَّكِئِينَ عَلَىٰ رَفْرَفٍ خُضْرٍ وَعَبْقَرِيٍّ حِسَانٍ"},{"verseKey":"55:77","surah":55,"ayah":77,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:78","surah":55,"ayah":78,"text":"تَبَارَكَ اسْمُ رَبِّكَ ذِي الْجَلَالِ وَالْإِكْرَامِ"},{"verseKey":"56:1","surah":56,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ إِذَا وَقَعَتِ الْوَاقِعَةُ"},{"verseKey":"56:2","surah":56,"ayah":2,"text":"لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ"},{"verseKey":"56:3","surah":56,"ayah":3,"text":"خَافِضَةٌ رَافِعَةٌ"},{"verseKey":"56:4","surah":56,"ayah":4,"text":"إِذَا رُجَّتِ الْأَرْضُ رَجًّا"},{"verseKey":"56:5","surah":56,"ayah":5,"text":"وَبُسَّتِ الْجِبَالُ بَسًّا"},{"verseKey":"56:6","surah":56,"ayah":6,"text":"فَكَانَتْ هَبَاءً مُنْبَثًّا"},{"verseKey":"56:7","surah":56,"ayah":7,"text":"وَكُنْتُمْ أَزْوَاجًا ثَلَاثَةً"},{"verseKey":"56:8","surah":56,"ayah":8,"text":"فَأَصْحَابُ الْمَيْمَنَةِ مَا أَصْحَابُ الْمَيْمَنَةِ"},{"verseKey":"56:9","surah":56,"ayah":9,"text":"وَأَصْحَابُ الْمَشْأَمَةِ مَا أَصْحَابُ الْمَشْأَمَةِ"},{"verseKey":"56:10","surah":56,"ayah":10,"text":"وَالسَّابِقُونَ السَّابِقُونَ"},{"verseKey":"56:11","surah":56,"ayah":11,"text":"أُولَٰئِكَ الْمُقَرَّبُونَ"},{"verseKey":"56:12","surah":56,"ayah":12,"text":"فِي جَنَّاتِ النَّعِيمِ"},{"verseKey":"56:13","surah":56,"ayah":13,"text":"ثُلَّةٌ مِنَ الْأَوَّلِينَ"},{"verseKey":"56:14","surah":56,"ayah":14,"text":"وَقَلِيلٌ مِنَ الْآخِرِينَ"},{"verseKey":"56:15","surah":56,"ayah":15,"text":"عَلَىٰ سُرُرٍ مَوْضُونَةٍ"},{"verseKey":"56:16","surah":56,"ayah":16,"text":"مُتَّكِئِينَ عَلَيْهَا مُتَقَابِلِينَ"}]}

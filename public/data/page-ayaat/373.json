{"pageNumber":373,"ayahs":[{"verseKey":"26:137","surah":26,"ayah":137,"text":"إِنْ هَٰذَا إِلَّا خُلُقُ الْأَوَّلِينَ"},{"verseKey":"26:138","surah":26,"ayah":138,"text":"وَمَا نَحْنُ بِمُعَذَّبِينَ"},{"verseKey":"26:139","surah":26,"ayah":139,"text":"فَكَذَّبُوهُ فَأَهْلَكْنَاهُمْ ۗ إِنَّ فِي ذَٰلِكَ لَآيَةً ۖ وَمَا كَانَ أَكْثَرُهُمْ مُؤْمِنِينَ"},{"verseKey":"26:140","surah":26,"ayah":140,"text":"وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ الرَّحِيمُ"},{"verseKey":"26:141","surah":26,"ayah":141,"text":"كَذَّبَتْ ثَمُودُ الْمُرْسَلِينَ"},{"verseKey":"26:142","surah":26,"ayah":142,"text":"إِذْ قَالَ لَهُمْ أَخُوهُمْ صَالِحٌ أَلَا تَتَّقُونَ"},{"verseKey":"26:143","surah":26,"ayah":143,"text":"إِنِّي لَكُمْ رَسُولٌ أَمِينٌ"},{"verseKey":"26:144","surah":26,"ayah":144,"text":"فَاتَّقُوا اللَّهَ وَأَطِيعُونِ"},{"verseKey":"26:145","surah":26,"ayah":145,"text":"وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِيَ إِلَّا عَلَىٰ رَبِّ الْعَالَمِينَ"},{"verseKey":"26:146","surah":26,"ayah":146,"text":"أَتُتْرَكُونَ فِي مَا هَاهُنَا آمِنِينَ"},{"verseKey":"26:147","surah":26,"ayah":147,"text":"فِي جَنَّاتٍ وَعُيُونٍ"},{"verseKey":"26:148","surah":26,"ayah":148,"text":"وَزُرُوعٍ وَنَخْلٍ طَلْعُهَا هَضِيمٌ"},{"verseKey":"26:149","surah":26,"ayah":149,"text":"وَتَنْحِتُونَ مِنَ الْجِبَالِ بُيُوتًا فَارِهِينَ"},{"verseKey":"26:150","surah":26,"ayah":150,"text":"فَاتَّقُوا اللَّهَ وَأَطِيعُونِ"},{"verseKey":"26:151","surah":26,"ayah":151,"text":"وَلَا تُطِيعُوا أَمْرَ الْمُسْرِفِينَ"},{"verseKey":"26:152","surah":26,"ayah":152,"text":"الَّذِينَ يُفْسِدُونَ فِي الْأَرْضِ وَلَا يُصْلِحُونَ"},{"verseKey":"26:153","surah":26,"ayah":153,"text":"قَالُوا إِنَّمَا أَنْتَ مِنَ الْمُسَحَّرِينَ"},{"verseKey":"26:154","surah":26,"ayah":154,"text":"مَا أَنْتَ إِلَّا بَشَرٌ مِثْلُنَا فَأْتِ بِآيَةٍ إِنْ كُنْتَ مِنَ الصَّادِقِينَ"},{"verseKey":"26:155","surah":26,"ayah":155,"text":"قَالَ هَٰذِهِ نَاقَةٌ لَهَا شِرْبٌ وَلَكُمْ شِرْبُ يَوْمٍ مَعْلُومٍ"},{"verseKey":"26:156","surah":26,"ayah":156,"text":"وَلَا تَمَسُّوهَا بِسُوءٍ فَيَأْخُذَكُمْ عَذَابُ يَوْمٍ عَظِيمٍ"},{"verseKey":"26:157","surah":26,"ayah":157,"text":"فَعَقَرُوهَا فَأَصْبَحُوا نَادِمِينَ"},{"verseKey":"26:158","surah":26,"ayah":158,"text":"فَأَخَذَهُمُ الْعَذَابُ ۗ إِنَّ فِي ذَٰلِكَ لَآيَةً ۖ وَمَا كَانَ أَكْثَرُهُمْ مُؤْمِنِينَ"},{"verseKey":"26:159","surah":26,"ayah":159,"text":"وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ الرَّحِيمُ"}]}

{"pageNumber":597,"ayahs":[{"verseKey":"94:3","surah":94,"ayah":3,"text":"الَّذِي أَنْقَضَ ظَهْرَكَ"},{"verseKey":"94:4","surah":94,"ayah":4,"text":"وَرَفَعْنَا لَكَ ذِكْرَكَ"},{"verseKey":"94:5","surah":94,"ayah":5,"text":"فَإِنَّ مَعَ الْعُسْرِ يُسْرًا"},{"verseKey":"94:6","surah":94,"ayah":6,"text":"إِنَّ مَعَ الْعُسْرِ يُسْرًا"},{"verseKey":"94:7","surah":94,"ayah":7,"text":"فَإِذَا فَرَغْتَ فَانْصَبْ"},{"verseKey":"94:8","surah":94,"ayah":8,"text":"وَإِلَىٰ رَبِّكَ فَارْغَبْ"},{"verseKey":"95:1","surah":95,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالتِّينِ وَالزَّيْتُونِ"},{"verseKey":"95:2","surah":95,"ayah":2,"text":"وَطُورِ سِينِينَ"},{"verseKey":"95:3","surah":95,"ayah":3,"text":"وَهَٰذَا الْبَلَدِ الْأَمِينِ"},{"verseKey":"95:4","surah":95,"ayah":4,"text":"لَقَدْ خَلَقْنَا الْإِنْسَانَ فِي أَحْسَنِ تَقْوِيمٍ"},{"verseKey":"95:5","surah":95,"ayah":5,"text":"ثُمَّ رَدَدْنَاهُ أَسْفَلَ سَافِلِينَ"},{"verseKey":"95:6","surah":95,"ayah":6,"text":"إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ"},{"verseKey":"95:7","surah":95,"ayah":7,"text":"فَمَا يُكَذِّبُكَ بَعْدُ بِالدِّينِ"},{"verseKey":"95:8","surah":95,"ayah":8,"text":"أَلَيْسَ اللَّهُ بِأَحْكَمِ الْحَاكِمِينَ"},{"verseKey":"96:1","surah":96,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ"},{"verseKey":"96:2","surah":96,"ayah":2,"text":"خَلَقَ الْإِنْسَانَ مِنْ عَلَقٍ"},{"verseKey":"96:3","surah":96,"ayah":3,"text":"اقْرَأْ وَرَبُّكَ الْأَكْرَمُ"},{"verseKey":"96:4","surah":96,"ayah":4,"text":"الَّذِي عَلَّمَ بِالْقَلَمِ"},{"verseKey":"96:5","surah":96,"ayah":5,"text":"عَلَّمَ الْإِنْسَانَ مَا لَمْ يَعْلَمْ"},{"verseKey":"96:6","surah":96,"ayah":6,"text":"كَلَّا إِنَّ الْإِنْسَانَ لَيَطْغَىٰ"},{"verseKey":"96:7","surah":96,"ayah":7,"text":"أَنْ رَآهُ اسْتَغْنَىٰ"},{"verseKey":"96:8","surah":96,"ayah":8,"text":"إِنَّ إِلَىٰ رَبِّكَ الرُّجْعَىٰ"},{"verseKey":"96:9","surah":96,"ayah":9,"text":"أَرَأَيْتَ الَّذِي يَنْهَىٰ"},{"verseKey":"96:10","surah":96,"ayah":10,"text":"عَبْدًا إِذَا صَلَّىٰ"},{"verseKey":"96:11","surah":96,"ayah":11,"text":"أَرَأَيْتَ إِنْ كَانَ عَلَى الْهُدَىٰ"},{"verseKey":"96:12","surah":96,"ayah":12,"text":"أَوْ أَمَرَ بِالتَّقْوَىٰ"}]}

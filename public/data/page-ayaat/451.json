{"pageNumber":451,"ayahs":[{"verseKey":"37:127","surah":37,"ayah":127,"text":"فَكَذَّبُوهُ فَإِنَّهُمْ لَمُحْضَرُونَ"},{"verseKey":"37:128","surah":37,"ayah":128,"text":"إِلَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ"},{"verseKey":"37:129","surah":37,"ayah":129,"text":"وَتَرَكْنَا عَلَيْهِ فِي الْآخِرِينَ"},{"verseKey":"37:130","surah":37,"ayah":130,"text":"سَلَامٌ عَلَىٰ إِلْ يَاسِينَ"},{"verseKey":"37:131","surah":37,"ayah":131,"text":"إِنَّا كَذَٰلِكَ نَجْزِي الْمُحْسِنِينَ"},{"verseKey":"37:132","surah":37,"ayah":132,"text":"إِنَّهُ مِنْ عِبَادِنَا الْمُؤْمِنِينَ"},{"verseKey":"37:133","surah":37,"ayah":133,"text":"وَإِنَّ لُوطًا لَمِنَ الْمُرْسَلِينَ"},{"verseKey":"37:134","surah":37,"ayah":134,"text":"إِذْ نَجَّيْنَاهُ وَأَهْلَهُ أَجْمَعِينَ"},{"verseKey":"37:135","surah":37,"ayah":135,"text":"إِلَّا عَجُوزًا فِي الْغَابِرِينَ"},{"verseKey":"37:136","surah":37,"ayah":136,"text":"ثُمَّ دَمَّرْنَا الْآخَرِينَ"},{"verseKey":"37:137","surah":37,"ayah":137,"text":"وَإِنَّكُمْ لَتَمُرُّونَ عَلَيْهِمْ مُصْبِحِينَ"},{"verseKey":"37:138","surah":37,"ayah":138,"text":"وَبِاللَّيْلِ ۗ أَفَلَا تَعْقِلُونَ"},{"verseKey":"37:139","surah":37,"ayah":139,"text":"وَإِنَّ يُونُسَ لَمِنَ الْمُرْسَلِينَ"},{"verseKey":"37:140","surah":37,"ayah":140,"text":"إِذْ أَبَقَ إِلَى الْفُلْكِ الْمَشْحُونِ"},{"verseKey":"37:141","surah":37,"ayah":141,"text":"فَسَاهَمَ فَكَانَ مِنَ الْمُدْحَضِينَ"},{"verseKey":"37:142","surah":37,"ayah":142,"text":"فَالْتَقَمَهُ الْحُوتُ وَهُوَ مُلِيمٌ"},{"verseKey":"37:143","surah":37,"ayah":143,"text":"فَلَوْلَا أَنَّهُ كَانَ مِنَ الْمُسَبِّحِينَ"},{"verseKey":"37:144","surah":37,"ayah":144,"text":"لَلَبِثَ فِي بَطْنِهِ إِلَىٰ يَوْمِ يُبْعَثُونَ"},{"verseKey":"37:145","surah":37,"ayah":145,"text":"۞ فَنَبَذْنَاهُ بِالْعَرَاءِ وَهُوَ سَقِيمٌ"},{"verseKey":"37:146","surah":37,"ayah":146,"text":"وَأَنْبَتْنَا عَلَيْهِ شَجَرَةً مِنْ يَقْطِينٍ"},{"verseKey":"37:147","surah":37,"ayah":147,"text":"وَأَرْسَلْنَاهُ إِلَىٰ مِائَةِ أَلْفٍ أَوْ يَزِيدُونَ"},{"verseKey":"37:148","surah":37,"ayah":148,"text":"فَآمَنُوا فَمَتَّعْنَاهُمْ إِلَىٰ حِينٍ"},{"verseKey":"37:149","surah":37,"ayah":149,"text":"فَاسْتَفْتِهِمْ أَلِرَبِّكَ الْبَنَاتُ وَلَهُمُ الْبَنُونَ"},{"verseKey":"37:150","surah":37,"ayah":150,"text":"أَمْ خَلَقْنَا الْمَلَائِكَةَ إِنَاثًا وَهُمْ شَاهِدُونَ"},{"verseKey":"37:151","surah":37,"ayah":151,"text":"أَلَا إِنَّهُمْ مِنْ إِفْكِهِمْ لَيَقُولُونَ"},{"verseKey":"37:152","surah":37,"ayah":152,"text":"وَلَدَ اللَّهُ وَإِنَّهُمْ لَكَاذِبُونَ"},{"verseKey":"37:153","surah":37,"ayah":153,"text":"أَصْطَفَى الْبَنَاتِ عَلَى الْبَنِينَ"}]}

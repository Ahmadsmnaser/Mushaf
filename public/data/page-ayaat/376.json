{"pageNumber":376,"ayahs":[{"verseKey":"26:207","surah":26,"ayah":207,"text":"مَا أَغْنَىٰ عَنْهُمْ مَا كَانُوا يُمَتَّعُونَ"},{"verseKey":"26:208","surah":26,"ayah":208,"text":"وَمَا أَهْلَكْنَا مِنْ قَرْيَةٍ إِلَّا لَهَا مُنْذِرُونَ"},{"verseKey":"26:209","surah":26,"ayah":209,"text":"ذِكْرَىٰ وَمَا كُنَّا ظَالِمِينَ"},{"verseKey":"26:210","surah":26,"ayah":210,"text":"وَمَا تَنَزَّلَتْ بِهِ الشَّيَاطِينُ"},{"verseKey":"26:211","surah":26,"ayah":211,"text":"وَمَا يَنْبَغِي لَهُمْ وَمَا يَسْتَطِيعُونَ"},{"verseKey":"26:212","surah":26,"ayah":212,"text":"إِنَّهُمْ عَنِ السَّمْعِ لَمَعْزُولُونَ"},{"verseKey":"26:213","surah":26,"ayah":213,"text":"فَلَا تَدْعُ مَعَ اللَّهِ إِلَٰهًا آخَرَ فَتَكُونَ مِنَ الْمُعَذَّبِينَ"},{"verseKey":"26:214","surah":26,"ayah":214,"text":"وَأَنْذِرْ عَشِيرَتَكَ الْأَقْرَبِينَ"},{"verseKey":"26:215","surah":26,"ayah":215,"text":"وَاخْفِضْ جَنَاحَكَ لِمَنِ اتَّبَعَكَ مِنَ الْمُؤْمِنِينَ"},{"verseKey":"26:216","surah":26,"ayah":216,"text":"فَإِنْ عَصَوْكَ فَقُلْ إِنِّي بَرِيءٌ مِمَّا تَعْمَلُونَ"},{"verseKey":"26:217","surah":26,"ayah":217,"text":"وَتَوَكَّلْ عَلَى الْعَزِيزِ الرَّحِيمِ"},{"verseKey":"26:218","surah":26,"ayah":218,"text":"الَّذِي يَرَاكَ حِينَ تَقُومُ"},{"verseKey":"26:219","surah":26,"ayah":219,"text":"وَتَقَلُّبَكَ فِي السَّاجِدِينَ"},{"verseKey":"26:220","surah":26,"ayah":220,"text":"إِنَّهُ هُوَ السَّمِيعُ الْعَلِيمُ"},{"verseKey":"26:221","surah":26,"ayah":221,"text":"هَلْ أُنَبِّئُكُمْ عَلَىٰ مَنْ تَنَزَّلُ الشَّيَاطِينُ"},{"verseKey":"26:222","surah":26,"ayah":222,"text":"تَنَزَّلُ عَلَىٰ كُلِّ أَفَّاكٍ أَثِيمٍ"},{"verseKey":"26:223","surah":26,"ayah":223,"text":"يُلْقُونَ السَّمْعَ وَأَكْثَرُهُمْ كَاذِبُونَ"},{"verseKey":"26:224","surah":26,"ayah":224,"text":"وَالشُّعَرَاءُ يَتَّبِعُهُمُ الْغَاوُونَ"},{"verseKey":"26:225","surah":26,"ayah":225,"text":"أَلَمْ تَرَ أَنَّهُمْ فِي كُلِّ وَادٍ يَهِيمُونَ"},{"verseKey":"26:226","surah":26,"ayah":226,"text":"وَأَنَّهُمْ يَقُولُونَ مَا لَا يَفْعَلُونَ"},{"verseKey":"26:227","surah":26,"ayah":227,"text":"إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ وَذَكَرُوا اللَّهَ كَثِيرًا وَانْتَصَرُوا مِنْ بَعْدِ مَا ظُلِمُوا ۗ وَسَيَعْلَمُ الَّذِينَ ظَلَمُوا أَيَّ مُنْقَلَبٍ يَنْقَلِبُونَ"}]}

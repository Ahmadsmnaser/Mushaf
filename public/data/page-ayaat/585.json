{"pageNumber":585,"ayahs":[{"verseKey":"80:1","surah":80,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ عَبَسَ وَتَوَلَّىٰ"},{"verseKey":"80:2","surah":80,"ayah":2,"text":"أَنْ جَاءَهُ الْأَعْمَىٰ"},{"verseKey":"80:3","surah":80,"ayah":3,"text":"وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّىٰ"},{"verseKey":"80:4","surah":80,"ayah":4,"text":"أَوْ يَذَّكَّرُ فَتَنْفَعَهُ الذِّكْرَىٰ"},{"verseKey":"80:5","surah":80,"ayah":5,"text":"أَمَّا مَنِ اسْتَغْنَىٰ"},{"verseKey":"80:6","surah":80,"ayah":6,"text":"فَأَنْتَ لَهُ تَصَدَّىٰ"},{"verseKey":"80:7","surah":80,"ayah":7,"text":"وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ"},{"verseKey":"80:8","surah":80,"ayah":8,"text":"وَأَمَّا مَنْ جَاءَكَ يَسْعَىٰ"},{"verseKey":"80:9","surah":80,"ayah":9,"text":"وَهُوَ يَخْشَىٰ"},{"verseKey":"80:10","surah":80,"ayah":10,"text":"فَأَنْتَ عَنْهُ تَلَهَّىٰ"},{"verseKey":"80:11","surah":80,"ayah":11,"text":"كَلَّا إِنَّهَا تَذْكِرَةٌ"},{"verseKey":"80:12","surah":80,"ayah":12,"text":"فَمَنْ شَاءَ ذَكَرَهُ"},{"verseKey":"80:13","surah":80,"ayah":13,"text":"فِي صُحُفٍ مُكَرَّمَةٍ"},{"verseKey":"80:14","surah":80,"ayah":14,"text":"مَرْفُوعَةٍ مُطَهَّرَةٍ"},{"verseKey":"80:15","surah":80,"ayah":15,"text":"بِأَيْدِي سَفَرَةٍ"},{"verseKey":"80:16","surah":80,"ayah":16,"text":"كِرَامٍ بَرَرَةٍ"},{"verseKey":"80:17","surah":80,"ayah":17,"text":"قُتِلَ الْإِنْسَانُ مَا أَكْفَرَهُ"},{"verseKey":"80:18","surah":80,"ayah":18,"text":"مِنْ أَيِّ شَيْءٍ خَلَقَهُ"},{"verseKey":"80:19","surah":80,"ayah":19,"text":"مِنْ نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ"},{"verseKey":"80:20","surah":80,"ayah":20,"text":"ثُمَّ السَّبِيلَ يَسَّرَهُ"},{"verseKey":"80:21","surah":80,"ayah":21,"text":"ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ"},{"verseKey":"80:22","surah":80,"ayah":22,"text":"ثُمَّ إِذَا شَاءَ أَنْشَرَهُ"},{"verseKey":"80:23","surah":80,"ayah":23,"text":"كَلَّا لَمَّا يَقْضِ مَا أَمَرَهُ"},{"verseKey":"80:24","surah":80,"ayah":24,"text":"فَلْيَنْظُرِ الْإِنْسَانُ إِلَىٰ طَعَامِهِ"},{"verseKey":"80:25","surah":80,"ayah":25,"text":"أَنَّا صَبَبْنَا الْمَاءَ صَبًّا"},{"verseKey":"80:26","surah":80,"ayah":26,"text":"ثُمَّ شَقَقْنَا الْأَرْضَ شَقًّا"},{"verseKey":"80:27","surah":80,"ayah":27,"text":"فَأَنْبَتْنَا فِيهَا حَبًّا"},{"verseKey":"80:28","surah":80,"ayah":28,"text":"وَعِنَبًا وَقَضْبًا"},{"verseKey":"80:29","surah":80,"ayah":29,"text":"وَزَيْتُونًا وَنَخْلًا"},{"verseKey":"80:30","surah":80,"ayah":30,"text":"وَحَدَائِقَ غُلْبًا"},{"verseKey":"80:31","surah":80,"ayah":31,"text":"وَفَاكِهَةً وَأَبًّا"},{"verseKey":"80:32","surah":80,"ayah":32,"text":"مَتَاعًا لَكُمْ وَلِأَنْعَامِكُمْ"},{"verseKey":"80:33","surah":80,"ayah":33,"text":"فَإِذَا جَاءَتِ الصَّاخَّةُ"},{"verseKey":"80:34","surah":80,"ayah":34,"text":"يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ"},{"verseKey":"80:35","surah":80,"ayah":35,"text":"وَأُمِّهِ وَأَبِيهِ"},{"verseKey":"80:36","surah":80,"ayah":36,"text":"وَصَاحِبَتِهِ وَبَنِيهِ"},{"verseKey":"80:37","surah":80,"ayah":37,"text":"لِكُلِّ امْرِئٍ مِنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ"},{"verseKey":"80:38","surah":80,"ayah":38,"text":"وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ"},{"verseKey":"80:39","surah":80,"ayah":39,"text":"ضَاحِكَةٌ مُسْتَبْشِرَةٌ"},{"verseKey":"80:40","surah":80,"ayah":40,"text":"وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ"}]}

{"pageNumber":587,"ayahs":[{"verseKey":"82:1","surah":82,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ إِذَا السَّمَاءُ انْفَطَرَتْ"},{"verseKey":"82:2","surah":82,"ayah":2,"text":"وَإِذَا الْكَوَاكِبُ انْتَثَرَتْ"},{"verseKey":"82:3","surah":82,"ayah":3,"text":"وَإِذَا الْبِحَارُ فُجِّرَتْ"},{"verseKey":"82:4","surah":82,"ayah":4,"text":"وَإِذَا الْقُبُورُ بُعْثِرَتْ"},{"verseKey":"82:5","surah":82,"ayah":5,"text":"عَلِمَتْ نَفْسٌ مَا قَدَّمَتْ وَأَخَّرَتْ"},{"verseKey":"82:6","surah":82,"ayah":6,"text":"يَا أَيُّهَا الْإِنْسَانُ مَا غَرَّكَ بِرَبِّكَ الْكَرِيمِ"},{"verseKey":"82:7","surah":82,"ayah":7,"text":"الَّذِي خَلَقَكَ فَسَوَّاكَ فَعَدَلَكَ"},{"verseKey":"82:8","surah":82,"ayah":8,"text":"فِي أَيِّ صُورَةٍ مَا شَاءَ رَكَّبَكَ"},{"verseKey":"82:9","surah":82,"ayah":9,"text":"كَلَّا بَلْ تُكَذِّبُونَ بِالدِّينِ"},{"verseKey":"82:10","surah":82,"ayah":10,"text":"وَإِنَّ عَلَيْكُمْ لَحَافِظِينَ"},{"verseKey":"82:11","surah":82,"ayah":11,"text":"كِرَامًا كَاتِبِينَ"},{"verseKey":"82:12","surah":82,"ayah":12,"text":"يَعْلَمُونَ مَا تَفْعَلُونَ"},{"verseKey":"82:13","surah":82,"ayah":13,"text":"إِنَّ الْأَبْرَارَ لَفِي نَعِيمٍ"},{"verseKey":"82:14","surah":82,"ayah":14,"text":"وَإِنَّ الْفُجَّارَ لَفِي جَحِيمٍ"},{"verseKey":"82:15","surah":82,"ayah":15,"text":"يَصْلَوْنَهَا يَوْمَ الدِّينِ"},{"verseKey":"82:16","surah":82,"ayah":16,"text":"وَمَا هُمْ عَنْهَا بِغَائِبِينَ"},{"verseKey":"82:17","surah":82,"ayah":17,"text":"وَمَا أَدْرَاكَ مَا يَوْمُ الدِّينِ"},{"verseKey":"82:18","surah":82,"ayah":18,"text":"ثُمَّ مَا أَدْرَاكَ مَا يَوْمُ الدِّينِ"},{"verseKey":"82:19","surah":82,"ayah":19,"text":"يَوْمَ لَا تَمْلِكُ نَفْسٌ لِنَفْسٍ شَيْئًا ۖ وَالْأَمْرُ يَوْمَئِذٍ لِلَّهِ"},{"verseKey":"83:1","surah":83,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَيْلٌ لِلْمُطَفِّفِينَ"},{"verseKey":"83:2","surah":83,"ayah":2,"text":"الَّذِينَ إِذَا اكْتَالُوا عَلَى النَّاسِ يَسْتَوْفُونَ"},{"verseKey":"83:3","surah":83,"ayah":3,"text":"وَإِذَا كَالُوهُمْ أَوْ وَزَنُوهُمْ يُخْسِرُونَ"},{"verseKey":"83:4","surah":83,"ayah":4,"text":"أَلَا يَظُنُّ أُولَٰئِكَ أَنَّهُمْ مَبْعُوثُونَ"}]}

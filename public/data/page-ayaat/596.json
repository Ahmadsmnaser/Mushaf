{"pageNumber":596,"ayahs":[{"verseKey":"92:10","surah":92,"ayah":10,"text":"فَسَنُيَسِّرُهُ لِلْعُسْرَىٰ"},{"verseKey":"92:11","surah":92,"ayah":11,"text":"وَمَا يُغْنِي عَنْهُ مَالُهُ إِذَا تَرَدَّىٰ"},{"verseKey":"92:12","surah":92,"ayah":12,"text":"إِنَّ عَلَيْنَا لَلْهُدَىٰ"},{"verseKey":"92:13","surah":92,"ayah":13,"text":"وَإِنَّ لَنَا لَلْآخِرَةَ وَالْأُولَىٰ"},{"verseKey":"92:14","surah":92,"ayah":14,"text":"فَأَنْذَرْتُكُمْ نَارًا تَلَظَّىٰ"},{"verseKey":"92:15","surah":92,"ayah":15,"text":"لَا يَصْلَاهَا إِلَّا الْأَشْقَى"},{"verseKey":"92:16","surah":92,"ayah":16,"text":"الَّذِي كَذَّبَ وَتَوَلَّىٰ"},{"verseKey":"92:17","surah":92,"ayah":17,"text":"وَسَيُجَنَّبُهَا الْأَتْقَى"},{"verseKey":"92:18","surah":92,"ayah":18,"text":"الَّذِي يُؤْتِي مَالَهُ يَتَزَكَّىٰ"},{"verseKey":"92:19","surah":92,"ayah":19,"text":"وَمَا لِأَحَدٍ عِنْدَهُ مِنْ نِعْمَةٍ تُجْزَىٰ"},{"verseKey":"92:20","surah":92,"ayah":20,"text":"إِلَّا ابْتِغَاءَ وَجْهِ رَبِّهِ الْأَعْلَىٰ"},{"verseKey":"92:21","surah":92,"ayah":21,"text":"وَلَسَوْفَ يَرْضَىٰ"},{"verseKey":"93:1","surah":93,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالضُّحَىٰ"},{"verseKey":"93:2","surah":93,"ayah":2,"text":"وَاللَّيْلِ إِذَا سَجَىٰ"},{"verseKey":"93:3","surah":93,"ayah":3,"text":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ"},{"verseKey":"93:4","surah":93,"ayah":4,"text":"وَلَلْآخِرَةُ خَيْرٌ لَكَ مِنَ الْأُولَىٰ"},{"verseKey":"93:5","surah":93,"ayah":5,"text":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰ"},{"verseKey":"93:6","surah":93,"ayah":6,"text":"أَلَمْ يَجِدْكَ يَتِيمًا فَآوَىٰ"},{"verseKey":"93:7","surah":93,"ayah":7,"text":"وَوَجَدَكَ ضَالًّا فَهَدَىٰ"},{"verseKey":"93:8","surah":93,"ayah":8,"text":"وَوَجَدَكَ عَائِلًا فَأَغْنَىٰ"},{"verseKey":"93:9","surah":93,"ayah":9,"text":"فَأَمَّا الْيَتِيمَ فَلَا تَقْهَرْ"},{"verseKey":"93:10","surah":93,"ayah":10,"text":"وَأَمَّا السَّائِلَ فَلَا تَنْهَرْ"},{"verseKey":"93:11","surah":93,"ayah":11,"text":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ"},{"verseKey":"94:1","surah":94,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ"},{"verseKey":"94:2","surah":94,"ayah":2,"text":"وَوَضَعْنَا عَنْكَ وِزْرَكَ"}]}

{"pageNumber":604,"ayahs":[{"verseKey":"112:1","surah":112,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ قُلْ هُوَ اللَّهُ أَحَدٌ"},{"verseKey":"112:2","surah":112,"ayah":2,"text":"اللَّهُ الصَّمَدُ"},{"verseKey":"112:3","surah":112,"ayah":3,"text":"لَمْ يَلِدْ وَلَمْ يُولَدْ"},{"verseKey":"112:4","surah":112,"ayah":4,"text":"وَلَمْ يَكُنْ لَهُ كُفُوًا أَحَدٌ"},{"verseKey":"113:1","surah":113,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ"},{"verseKey":"113:2","surah":113,"ayah":2,"text":"مِنْ شَرِّ مَا خَلَقَ"},{"verseKey":"113:3","surah":113,"ayah":3,"text":"وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ"},{"verseKey":"113:4","surah":113,"ayah":4,"text":"وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ"},{"verseKey":"113:5","surah":113,"ayah":5,"text":"وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ"},{"verseKey":"114:1","surah":114,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ النَّاسِ"},{"verseKey":"114:2","surah":114,"ayah":2,"text":"مَلِكِ النَّاسِ"},{"verseKey":"114:3","surah":114,"ayah":3,"text":"إِلَٰهِ النَّاسِ"},{"verseKey":"114:4","surah":114,"ayah":4,"text":"مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ"},{"verseKey":"114:5","surah":114,"ayah":5,"text":"الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ"},{"verseKey":"114:6","surah":114,"ayah":6,"text":"مِنَ الْجِنَّةِ وَالنَّاسِ"}]}

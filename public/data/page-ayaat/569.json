{"pageNumber":569,"ayahs":[{"verseKey":"70:11","surah":70,"ayah":11,"text":"يُبَصَّرُونَهُمْ ۚ يَوَدُّ الْمُجْرِمُ لَوْ يَفْتَدِي مِنْ عَذَابِ يَوْمِئِذٍ بِبَنِيهِ"},{"verseKey":"70:12","surah":70,"ayah":12,"text":"وَصَاحِبَتِهِ وَأَخِيهِ"},{"verseKey":"70:13","surah":70,"ayah":13,"text":"وَفَصِيلَتِهِ الَّتِي تُؤْوِيهِ"},{"verseKey":"70:14","surah":70,"ayah":14,"text":"وَمَنْ فِي الْأَرْضِ جَمِيعًا ثُمَّ يُنْجِيهِ"},{"verseKey":"70:15","surah":70,"ayah":15,"text":"كَلَّا ۖ إِنَّهَا لَظَىٰ"},{"verseKey":"70:16","surah":70,"ayah":16,"text":"نَزَّاعَةً لِلشَّوَىٰ"},{"verseKey":"70:17","surah":70,"ayah":17,"text":"تَدْعُو مَنْ أَدْبَرَ وَتَوَلَّىٰ"},{"verseKey":"70:18","surah":70,"ayah":18,"text":"وَجَمَعَ فَأَوْعَىٰ"},{"verseKey":"70:19","surah":70,"ayah":19,"text":"۞ إِنَّ الْإِنْسَانَ خُلِقَ هَلُوعًا"},{"verseKey":"70:20","surah":70,"ayah":20,"text":"إِذَا مَسَّهُ الشَّرُّ جَزُوعًا"},{"verseKey":"70:21","surah":70,"ayah":21,"text":"وَإِذَا مَسَّهُ الْخَيْرُ مَنُوعًا"},{"verseKey":"70:22","surah":70,"ayah":22,"text":"إِلَّا الْمُصَلِّينَ"},{"verseKey":"70:23","surah":70,"ayah":23,"text":"الَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ دَائِمُونَ"},{"verseKey":"70:24","surah":70,"ayah":24,"text":"وَالَّذِينَ فِي أَمْوَالِهِمْ حَقٌّ مَعْلُومٌ"},{"verseKey":"70:25","surah":70,"ayah":25,"text":"لِلسَّائِلِ وَالْمَحْرُومِ"},{"verseKey":"70:26","surah":70,"ayah":26,"text":"وَالَّذِينَ يُصَدِّقُونَ بِيَوْمِ الدِّينِ"},{"verseKey":"70:27","surah":70,"ayah":27,"text":"وَالَّذِينَ هُمْ مِنْ عَذَابِ رَبِّهِمْ مُشْفِقُونَ"},{"verseKey":"70:28","surah":70,"ayah":28,"text":"إِنَّ عَذَابَ رَبِّهِمْ غَيْرُ مَأْمُونٍ"},{"verseKey":"70:29","surah":70,"ayah":29,"text":"وَالَّذِينَ هُمْ لِفُرُوجِهِمْ حَافِظُونَ"},{"verseKey":"70:30","surah":70,"ayah":30,"text":"إِلَّا عَلَىٰ أَزْوَاجِهِمْ أَوْ مَا مَلَكَتْ أَيْمَانُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَ"},{"verseKey":"70:31","surah":70,"ayah":31,"text":"فَمَنِ ابْتَغَىٰ وَرَاءَ ذَٰلِكَ فَأُولَٰئِكَ هُمُ الْعَادُونَ"},{"verseKey":"70:32","surah":70,"ayah":32,"text":"وَالَّذِينَ هُمْ لِأَمَانَاتِهِمْ وَعَهْدِهِمْ رَاعُونَ"},{"verseKey":"70:33","surah":70,"ayah":33,"text":"وَالَّذِينَ هُمْ بِشَهَادَاتِهِمْ قَائِمُونَ"},{"verseKey":"70:34","surah":70,"ayah":34,"text":"وَالَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ يُحَافِظُونَ"},{"verseKey":"70:35","surah":70,"ayah":35,"text":"أُولَٰئِكَ فِي جَنَّاتٍ مُكْرَمُونَ"},{"verseKey":"70:36","surah":70,"ayah":36,"text":"فَمَالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ"},{"verseKey":"70:37","surah":70,"ayah":37,"text":"عَنِ الْيَمِينِ وَعَنِ الشِّمَالِ عِزِينَ"},{"verseKey":"70:38","surah":70,"ayah":38,"text":"أَيَطْمَعُ كُلُّ امْرِئٍ مِنْهُمْ أَنْ يُدْخَلَ جَنَّةَ نَعِيمٍ"},{"verseKey":"70:39","surah":70,"ayah":39,"text":"كَلَّا ۖ إِنَّا خَلَقْنَاهُمْ مِمَّا يَعْلَمُونَ"},{"verseKey":"70:40","surah":70,"ayah":40,"text":"فَلَا أُقْسِمُ بِرَبِّ الْمَشَارِقِ وَالْمَغَارِبِ إِنَّا لَقَادِرُونَ"}]}

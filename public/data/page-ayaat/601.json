{"pageNumber":601,"ayahs":[{"verseKey":"103:1","surah":103,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالْعَصْرِ"},{"verseKey":"103:2","surah":103,"ayah":2,"text":"إِنَّ الْإِنْسَانَ لَفِي خُسْرٍ"},{"verseKey":"103:3","surah":103,"ayah":3,"text":"إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ وَتَوَاصَوْا بِالْحَقِّ وَتَوَاصَوْا بِالصَّبْرِ"},{"verseKey":"104:1","surah":104,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَيْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ"},{"verseKey":"104:2","surah":104,"ayah":2,"text":"الَّذِي جَمَعَ مَالًا وَعَدَّدَهُ"},{"verseKey":"104:3","surah":104,"ayah":3,"text":"يَحْسَبُ أَنَّ مَالَهُ أَخْلَدَهُ"},{"verseKey":"104:4","surah":104,"ayah":4,"text":"كَلَّا ۖ لَيُنْبَذَنَّ فِي الْحُطَمَةِ"},{"verseKey":"104:5","surah":104,"ayah":5,"text":"وَمَا أَدْرَاكَ مَا الْحُطَمَةُ"},{"verseKey":"104:6","surah":104,"ayah":6,"text":"نَارُ اللَّهِ الْمُوقَدَةُ"},{"verseKey":"104:7","surah":104,"ayah":7,"text":"الَّتِي تَطَّلِعُ عَلَى الْأَفْئِدَةِ"},{"verseKey":"104:8","surah":104,"ayah":8,"text":"إِنَّهَا عَلَيْهِمْ مُؤْصَدَةٌ"},{"verseKey":"104:9","surah":104,"ayah":9,"text":"فِي عَمَدٍ مُمَدَّدَةٍ"},{"verseKey":"105:1","surah":105,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَابِ الْفِيلِ"},{"verseKey":"105:2","surah":105,"ayah":2,"text":"أَلَمْ يَجْعَلْ كَيْدَهُمْ فِي تَضْلِيلٍ"},{"verseKey":"105:3","surah":105,"ayah":3,"text":"وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ"},{"verseKey":"105:4","surah":105,"ayah":4,"text":"تَرْمِيهِمْ بِحِجَارَةٍ مِنْ سِجِّيلٍ"},{"verseKey":"105:5","surah":105,"ayah":5,"text":"فَجَعَلَهُمْ كَعَصْفٍ مَأْكُولٍ"}]}

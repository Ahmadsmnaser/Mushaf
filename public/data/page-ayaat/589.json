{"pageNumber":589,"ayahs":[{"verseKey":"83:34","surah":83,"ayah":34,"text":"فَالْيَوْمَ الَّذِينَ آمَنُوا مِنَ الْكُفَّارِ يَضْحَكُونَ"},{"verseKey":"83:35","surah":83,"ayah":35,"text":"عَلَى الْأَرَائِكِ يَنْظُرُونَ"},{"verseKey":"83:36","surah":83,"ayah":36,"text":"هَلْ ثُوِّبَ الْكُفَّارُ مَا كَانُوا يَفْعَلُونَ"},{"verseKey":"84:1","surah":84,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ إِذَا السَّمَاءُ انْشَقَّتْ"},{"verseKey":"84:2","surah":84,"ayah":2,"text":"وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ"},{"verseKey":"84:3","surah":84,"ayah":3,"text":"وَإِذَا الْأَرْضُ مُدَّتْ"},{"verseKey":"84:4","surah":84,"ayah":4,"text":"وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ"},{"verseKey":"84:5","surah":84,"ayah":5,"text":"وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ"},{"verseKey":"84:6","surah":84,"ayah":6,"text":"يَا أَيُّهَا الْإِنْسَانُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدْحًا فَمُلَاقِيهِ"},{"verseKey":"84:7","surah":84,"ayah":7,"text":"فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ"},{"verseKey":"84:8","surah":84,"ayah":8,"text":"فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا"},{"verseKey":"84:9","surah":84,"ayah":9,"text":"وَيَنْقَلِبُ إِلَىٰ أَهْلِهِ مَسْرُورًا"},{"verseKey":"84:10","surah":84,"ayah":10,"text":"وَأَمَّا مَنْ أُوتِيَ كِتَابَهُ وَرَاءَ ظَهْرِهِ"},{"verseKey":"84:11","surah":84,"ayah":11,"text":"فَسَوْفَ يَدْعُو ثُبُورًا"},{"verseKey":"84:12","surah":84,"ayah":12,"text":"وَيَصْلَىٰ سَعِيرًا"},{"verseKey":"84:13","surah":84,"ayah":13,"text":"إِنَّهُ كَانَ فِي أَهْلِهِ مَسْرُورًا"},{"verseKey":"84:14","surah":84,"ayah":14,"text":"إِنَّهُ ظَنَّ أَنْ لَنْ يَحُورَ"},{"verseKey":"84:15","surah":84,"ayah":15,"text":"بَلَىٰ إِنَّ رَبَّهُ كَانَ بِهِ بَصِيرًا"},{"verseKey":"84:16","surah":84,"ayah":16,"text":"فَلَا أُقْسِمُ بِالشَّفَقِ"},{"verseKey":"84:17","surah":84,"ayah":17,"text":"وَاللَّيْلِ وَمَا وَسَقَ"},{"verseKey":"84:18","surah":84,"ayah":18,"text":"وَالْقَمَرِ إِذَا اتَّسَقَ"},{"verseKey":"84:19","surah":84,"ayah":19,"text":"لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ"},{"verseKey":"84:20","surah":84,"ayah":20,"text":"فَمَا لَهُمْ لَا يُؤْمِنُونَ"},{"verseKey":"84:21","surah":84,"ayah":21,"text":"وَإِذَا قُرِئَ عَلَيْهِمُ الْقُرْآنُ لَا يَسْجُدُونَ ۩"},{"verseKey":"84:22","surah":84,"ayah":22,"text":"بَلِ الَّذِينَ كَفَرُوا يُكَذِّبُونَ"},{"verseKey":"84:23","surah":84,"ayah":23,"text":"وَاللَّهُ أَعْلَمُ بِمَا يُوعُونَ"},{"verseKey":"84:24","surah":84,"ayah":24,"text":"فَبَشِّرْهُمْ بِعَذَابٍ أَلِيمٍ"}]}

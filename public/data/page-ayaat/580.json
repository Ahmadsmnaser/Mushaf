{"pageNumber":580,"ayahs":[{"verseKey":"76:26","surah":76,"ayah":26,"text":"وَمِنَ اللَّيْلِ فَاسْجُدْ لَهُ وَسَبِّحْهُ لَيْلًا طَوِيلًا"},{"verseKey":"76:27","surah":76,"ayah":27,"text":"إِنَّ هَٰؤُلَاءِ يُحِبُّونَ الْعَاجِلَةَ وَيَذَرُونَ وَرَاءَهُمْ يَوْمًا ثَقِيلًا"},{"verseKey":"76:28","surah":76,"ayah":28,"text":"نَحْنُ خَلَقْنَاهُمْ وَشَدَدْنَا أَسْرَهُمْ ۖ وَإِذَا شِئْنَا بَدَّلْنَا أَمْثَالَهُمْ تَبْدِيلًا"},{"verseKey":"76:29","surah":76,"ayah":29,"text":"إِنَّ هَٰذِهِ تَذْكِرَةٌ ۖ فَمَنْ شَاءَ اتَّخَذَ إِلَىٰ رَبِّهِ سَبِيلًا"},{"verseKey":"76:30","surah":76,"ayah":30,"text":"وَمَا تَشَاءُونَ إِلَّا أَنْ يَشَاءَ اللَّهُ ۚ إِنَّ اللَّهَ كَانَ عَلِيمًا حَكِيمًا"},{"verseKey":"76:31","surah":76,"ayah":31,"text":"يُدْخِلُ مَنْ يَشَاءُ فِي رَحْمَتِهِ ۚ وَالظَّالِمِينَ أَعَدَّ لَهُمْ عَذَابًا أَلِيمًا"},{"verseKey":"77:1","surah":77,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالْمُرْسَلَاتِ عُرْفًا"},{"verseKey":"77:2","surah":77,"ayah":2,"text":"فَالْعَاصِفَاتِ عَصْفًا"},{"verseKey":"77:3","surah":77,"ayah":3,"text":"وَالنَّاشِرَاتِ نَشْرًا"},{"verseKey":"77:4","surah":77,"ayah":4,"text":"فَالْفَارِقَاتِ فَرْقًا"},{"verseKey":"77:5","surah":77,"ayah":5,"text":"فَالْمُلْقِيَاتِ ذِكْرًا"},{"verseKey":"77:6","surah":77,"ayah":6,"text":"عُذْرًا أَوْ نُذْرًا"},{"verseKey":"77:7","surah":77,"ayah":7,"text":"إِنَّمَا تُوعَدُونَ لَوَاقِعٌ"},{"verseKey":"77:8","surah":77,"ayah":8,"text":"فَإِذَا النُّجُومُ طُمِسَتْ"},{"verseKey":"77:9","surah":77,"ayah":9,"text":"وَإِذَا السَّمَاءُ فُرِجَتْ"},{"verseKey":"77:10","surah":77,"ayah":10,"text":"وَإِذَا الْجِبَالُ نُسِفَتْ"},{"verseKey":"77:11","surah":77,"ayah":11,"text":"وَإِذَا الرُّسُلُ أُقِّتَتْ"},{"verseKey":"77:12","surah":77,"ayah":12,"text":"لِأَيِّ يَوْمٍ أُجِّلَتْ"},{"verseKey":"77:13","surah":77,"ayah":13,"text":"لِيَوْمِ الْفَصْلِ"},{"verseKey":"77:14","surah":77,"ayah":14,"text":"وَمَا أَدْرَاكَ مَا يَوْمُ الْفَصْلِ"},{"verseKey":"77:15","surah":77,"ayah":15,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"77:16","surah":77,"ayah":16,"text":"أَلَمْ نُهْلِكِ الْأَوَّلِينَ"},{"verseKey":"77:17","surah":77,"ayah":17,"text":"ثُمَّ نُتْبِعُهُمُ الْآخِرِينَ"},{"verseKey":"77:18","surah":77,"ayah":18,"text":"كَذَٰلِكَ نَفْعَلُ بِالْمُجْرِمِينَ"},{"verseKey":"77:19","surah":77,"ayah":19,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"}]}

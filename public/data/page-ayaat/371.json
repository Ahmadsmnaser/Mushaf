{"pageNumber":371,"ayahs":[{"verseKey":"26:84","surah":26,"ayah":84,"text":"وَاجْعَلْ لِي لِسَانَ صِدْقٍ فِي الْآخِرِينَ"},{"verseKey":"26:85","surah":26,"ayah":85,"text":"وَاجْعَلْنِي مِنْ وَرَثَةِ جَنَّةِ النَّعِيمِ"},{"verseKey":"26:86","surah":26,"ayah":86,"text":"وَاغْفِرْ لِأَبِي إِنَّهُ كَانَ مِنَ الضَّالِّينَ"},{"verseKey":"26:87","surah":26,"ayah":87,"text":"وَلَا تُخْزِنِي يَوْمَ يُبْعَثُونَ"},{"verseKey":"26:88","surah":26,"ayah":88,"text":"يَوْمَ لَا يَنْفَعُ مَالٌ وَلَا بَنُونَ"},{"verseKey":"26:89","surah":26,"ayah":89,"text":"إِلَّا مَنْ أَتَى اللَّهَ بِقَلْبٍ سَلِيمٍ"},{"verseKey":"26:90","surah":26,"ayah":90,"text":"وَأُزْلِفَتِ الْجَنَّةُ لِلْمُتَّقِينَ"},{"verseKey":"26:91","surah":26,"ayah":91,"text":"وَبُرِّزَتِ الْجَحِيمُ لِلْغَاوِينَ"},{"verseKey":"26:92","surah":26,"ayah":92,"text":"وَقِيلَ لَهُمْ أَيْنَ مَا كُنْتُمْ تَعْبُدُونَ"},{"verseKey":"26:93","surah":26,"ayah":93,"text":"مِنْ دُونِ اللَّهِ هَلْ يَنْصُرُونَكُمْ أَوْ يَنْتَصِرُونَ"},{"verseKey":"26:94","surah":26,"ayah":94,"text":"فَكُبْكِبُوا فِيهَا هُمْ وَالْغَاوُونَ"},{"verseKey":"26:95","surah":26,"ayah":95,"text":"وَجُنُودُ إِبْلِيسَ أَجْمَعُونَ"},{"verseKey":"26:96","surah":26,"ayah":96,"text":"قَالُوا وَهُمْ فِيهَا يَخْتَصِمُونَ"},{"verseKey":"26:97","surah":26,"ayah":97,"text":"تَاللَّهِ إِنْ كُنَّا لَفِي ضَلَالٍ مُبِينٍ"},{"verseKey":"26:98","surah":26,"ayah":98,"text":"إِذْ نُسَوِّيكُمْ بِرَبِّ الْعَالَمِينَ"},{"verseKey":"26:99","surah":26,"ayah":99,"text":"وَمَا أَضَلَّنَا إِلَّا الْمُجْرِمُونَ"},{"verseKey":"26:100","surah":26,"ayah":100,"text":"فَمَا لَنَا مِنْ شَافِعِينَ"},{"verseKey":"26:101","surah":26,"ayah":101,"text":"وَلَا صَدِيقٍ حَمِيمٍ"},{"verseKey":"26:102","surah":26,"ayah":102,"text":"فَلَوْ أَنَّ لَنَا كَرَّةً فَنَكُونَ مِنَ الْمُؤْمِنِينَ"},{"verseKey":"26:103","surah":26,"ayah":103,"text":"إِنَّ فِي ذَٰلِكَ لَآيَةً ۖ وَمَا كَانَ أَكْثَرُهُمْ مُؤْمِنِينَ"},{"verseKey":"26:104","surah":26,"ayah":104,"text":"وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ الرَّحِيمُ"},{"verseKey":"26:105","surah":26,"ayah":105,"text":"كَذَّبَتْ قَوْمُ نُوحٍ الْمُرْسَلِينَ"},{"verseKey":"26:106","surah":26,"ayah":106,"text":"إِذْ قَالَ لَهُمْ أَخُوهُمْ نُوحٌ أَلَا تَتَّقُونَ"},{"verseKey":"26:107","surah":26,"ayah":107,"text":"إِنِّي لَكُمْ رَسُولٌ أَمِينٌ"},{"verseKey":"26:108","surah":26,"ayah":108,"text":"فَاتَّقُوا اللَّهَ وَأَطِيعُونِ"},{"verseKey":"26:109","surah":26,"ayah":109,"text":"وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِيَ إِلَّا عَلَىٰ رَبِّ الْعَالَمِينَ"},{"verseKey":"26:110","surah":26,"ayah":110,"text":"فَاتَّقُوا اللَّهَ وَأَطِيعُونِ"},{"verseKey":"26:111","surah":26,"ayah":111,"text":"۞ قَالُوا أَنُؤْمِنُ لَكَ وَاتَّبَعَكَ الْأَرْذَلُونَ"}]}

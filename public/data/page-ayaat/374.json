{"pageNumber":374,"ayahs":[{"verseKey":"26:160","surah":26,"ayah":160,"text":"كَذَّبَتْ قَوْمُ لُوطٍ الْمُرْسَلِينَ"},{"verseKey":"26:161","surah":26,"ayah":161,"text":"إِذْ قَالَ لَهُمْ أَخُوهُمْ لُوطٌ أَلَا تَتَّقُونَ"},{"verseKey":"26:162","surah":26,"ayah":162,"text":"إِنِّي لَكُمْ رَسُولٌ أَمِينٌ"},{"verseKey":"26:163","surah":26,"ayah":163,"text":"فَاتَّقُوا اللَّهَ وَأَطِيعُونِ"},{"verseKey":"26:164","surah":26,"ayah":164,"text":"وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِيَ إِلَّا عَلَىٰ رَبِّ الْعَالَمِينَ"},{"verseKey":"26:165","surah":26,"ayah":165,"text":"أَتَأْتُونَ الذُّكْرَانَ مِنَ الْعَالَمِينَ"},{"verseKey":"26:166","surah":26,"ayah":166,"text":"وَتَذَرُونَ مَا خَلَقَ لَكُمْ رَبُّكُمْ مِنْ أَزْوَاجِكُمْ ۚ بَلْ أَنْتُمْ قَوْمٌ عَادُونَ"},{"verseKey":"26:167","surah":26,"ayah":167,"text":"قَالُوا لَئِنْ لَمْ تَنْتَهِ يَا لُوطُ لَتَكُونَنَّ مِنَ الْمُخْرَجِينَ"},{"verseKey":"26:168","surah":26,"ayah":168,"text":"قَالَ إِنِّي لِعَمَلِكُمْ مِنَ الْقَالِينَ"},{"verseKey":"26:169","surah":26,"ayah":169,"text":"رَبِّ نَجِّنِي وَأَهْلِي مِمَّا يَعْمَلُونَ"},{"verseKey":"26:170","surah":26,"ayah":170,"text":"فَنَجَّيْنَاهُ وَأَهْلَهُ أَجْمَعِينَ"},{"verseKey":"26:171","surah":26,"ayah":171,"text":"إِلَّا عَجُوزًا فِي الْغَابِرِينَ"},{"verseKey":"26:172","surah":26,"ayah":172,"text":"ثُمَّ دَمَّرْنَا الْآخَرِينَ"},{"verseKey":"26:173","surah":26,"ayah":173,"text":"وَأَمْطَرْنَا عَلَيْهِمْ مَطَرًا ۖ فَسَاءَ مَطَرُ الْمُنْذَرِينَ"},{"verseKey":"26:174","surah":26,"ayah":174,"text":"إِنَّ فِي ذَٰلِكَ لَآيَةً ۖ وَمَا كَانَ أَكْثَرُهُمْ مُؤْمِنِينَ"},{"verseKey":"26:175","surah":26,"ayah":175,"text":"وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ الرَّحِيمُ"},{"verseKey":"26:176","surah":26,"ayah":176,"text":"كَذَّبَ أَصْحَابُ الْأَيْكَةِ الْمُرْسَلِينَ"},{"verseKey":"26:177","surah":26,"ayah":177,"text":"إِذْ قَالَ لَهُمْ شُعَيْبٌ أَلَا تَتَّقُونَ"},{"verseKey":"26:178","surah":26,"ayah":178,"text":"إِنِّي لَكُمْ رَسُولٌ أَمِينٌ"},{"verseKey":"26:179","surah":26,"ayah":179,"text":"فَاتَّقُوا اللَّهَ وَأَطِيعُونِ"},{"verseKey":"26:180","surah":26,"ayah":180,"text":"وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِيَ إِلَّا عَلَىٰ رَبِّ الْعَالَمِينَ"},{"verseKey":"26:181","surah":26,"ayah":181,"text":"۞ أَوْفُوا الْكَيْلَ وَلَا تَكُونُوا مِنَ الْمُخْسِرِينَ"},{"verseKey":"26:182","surah":26,"ayah":182,"text":"وَزِنُوا بِالْقِسْطَاسِ الْمُسْتَقِيمِ"},{"verseKey":"26:183","surah":26,"ayah":183,"text":"وَلَا تَبْخَسُوا النَّاسَ أَشْيَاءَهُمْ وَلَا تَعْثَوْا فِي الْأَرْضِ مُفْسِدِينَ"}]}

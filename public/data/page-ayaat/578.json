{"pageNumber":578,"ayahs":[{"verseKey":"75:20","surah":75,"ayah":20,"text":"كَلَّا بَلْ تُحِبُّونَ الْعَاجِلَةَ"},{"verseKey":"75:21","surah":75,"ayah":21,"text":"وَتَذَرُونَ الْآخِرَةَ"},{"verseKey":"75:22","surah":75,"ayah":22,"text":"وُجُوهٌ يَوْمَئِذٍ نَاضِرَةٌ"},{"verseKey":"75:23","surah":75,"ayah":23,"text":"إِلَىٰ رَبِّهَا نَاظِرَةٌ"},{"verseKey":"75:24","surah":75,"ayah":24,"text":"وَوُجُوهٌ يَوْمَئِذٍ بَاسِرَةٌ"},{"verseKey":"75:25","surah":75,"ayah":25,"text":"تَظُنُّ أَنْ يُفْعَلَ بِهَا فَاقِرَةٌ"},{"verseKey":"75:26","surah":75,"ayah":26,"text":"كَلَّا إِذَا بَلَغَتِ التَّرَاقِيَ"},{"verseKey":"75:27","surah":75,"ayah":27,"text":"وَقِيلَ مَنْ ۜ رَاقٍ"},{"verseKey":"75:28","surah":75,"ayah":28,"text":"وَظَنَّ أَنَّهُ الْفِرَاقُ"},{"verseKey":"75:29","surah":75,"ayah":29,"text":"وَالْتَفَّتِ السَّاقُ بِالسَّاقِ"},{"verseKey":"75:30","surah":75,"ayah":30,"text":"إِلَىٰ رَبِّكَ يَوْمَئِذٍ الْمَسَاقُ"},{"verseKey":"75:31","surah":75,"ayah":31,"text":"فَلَا صَدَّقَ وَلَا صَلَّىٰ"},{"verseKey":"75:32","surah":75,"ayah":32,"text":"وَلَٰكِنْ كَذَّبَ وَتَوَلَّىٰ"},{"verseKey":"75:33","surah":75,"ayah":33,"text":"ثُمَّ ذَهَبَ إِلَىٰ أَهْلِهِ يَتَمَطَّىٰ"},{"verseKey":"75:34","surah":75,"ayah":34,"text":"أَوْلَىٰ لَكَ فَأَوْلَىٰ"},{"verseKey":"75:35","surah":75,"ayah":35,"text":"ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰ"},{"verseKey":"75:36","surah":75,"ayah":36,"text":"أَيَحْسَبُ الْإِنْسَانُ أَنْ يُتْرَكَ سُدًى"},{"verseKey":"75:37","surah":75,"ayah":37,"text":"أَلَمْ يَكُ نُطْفَةً مِنْ مَنِيٍّ يُمْنَىٰ"},{"verseKey":"75:38","surah":75,"ayah":38,"text":"ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ"},{"verseKey":"75:39","surah":75,"ayah":39,"text":"فَجَعَلَ مِنْهُ الزَّوْجَيْنِ الذَّكَرَ وَالْأُنْثَىٰ"},{"verseKey":"75:40","surah":75,"ayah":40,"text":"أَلَيْسَ ذَٰلِكَ بِقَادِرٍ عَلَىٰ أَنْ يُحْيِيَ الْمَوْتَىٰ"},{"verseKey":"76:1","surah":76,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ هَلْ أَتَىٰ عَلَى الْإِنْسَانِ حِينٌ مِنَ الدَّهْرِ لَمْ يَكُنْ شَيْئًا مَذْكُورًا"},{"verseKey":"76:2","surah":76,"ayah":2,"text":"إِنَّا خَلَقْنَا الْإِنْسَانَ مِنْ نُطْفَةٍ أَمْشَاجٍ نَبْتَلِيهِ فَجَعَلْنَاهُ سَمِيعًا بَصِيرًا"},{"verseKey":"76:3","surah":76,"ayah":3,"text":"إِنَّا هَدَيْنَاهُ السَّبِيلَ إِمَّا شَاكِرًا وَإِمَّا كَفُورًا"},{"verseKey":"76:4","surah":76,"ayah":4,"text":"إِنَّا أَعْتَدْنَا لِلْكَافِرِينَ سَلَاسِلَ وَأَغْلَالًا وَسَعِيرًا"},{"verseKey":"76:5","surah":76,"ayah":5,"text":"إِنَّ الْأَبْرَارَ يَشْرَبُونَ مِنْ كَأْسٍ كَانَ مِزَاجُهَا كَافُورًا"}]}

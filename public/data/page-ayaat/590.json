{"pageNumber":590,"ayahs":[{"verseKey":"84:25","surah":84,"ayah":25,"text":"إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ"},{"verseKey":"85:1","surah":85,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالسَّمَاءِ ذَاتِ الْبُرُوجِ"},{"verseKey":"85:2","surah":85,"ayah":2,"text":"وَالْيَوْمِ الْمَوْعُودِ"},{"verseKey":"85:3","surah":85,"ayah":3,"text":"وَشَاهِدٍ وَمَشْهُودٍ"},{"verseKey":"85:4","surah":85,"ayah":4,"text":"قُتِلَ أَصْحَابُ الْأُخْدُودِ"},{"verseKey":"85:5","surah":85,"ayah":5,"text":"النَّارِ ذَاتِ الْوَقُودِ"},{"verseKey":"85:6","surah":85,"ayah":6,"text":"إِذْ هُمْ عَلَيْهَا قُعُودٌ"},{"verseKey":"85:7","surah":85,"ayah":7,"text":"وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِالْمُؤْمِنِينَ شُهُودٌ"},{"verseKey":"85:8","surah":85,"ayah":8,"text":"وَمَا نَقَمُوا مِنْهُمْ إِلَّا أَنْ يُؤْمِنُوا بِاللَّهِ الْعَزِيزِ الْحَمِيدِ"},{"verseKey":"85:9","surah":85,"ayah":9,"text":"الَّذِي لَهُ مُلْكُ السَّمَاوَاتِ وَالْأَرْضِ ۚ وَاللَّهُ عَلَىٰ كُلِّ شَيْءٍ شَهِيدٌ"},{"verseKey":"85:10","surah":85,"ayah":10,"text":"إِنَّ الَّذِينَ فَتَنُوا الْمُؤْمِنِينَ وَالْمُؤْمِنَاتِ ثُمَّ لَمْ يَتُوبُوا فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ الْحَرِيقِ"},{"verseKey":"85:11","surah":85,"ayah":11,"text":"إِنَّ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ لَهُمْ جَنَّاتٌ تَجْرِي مِنْ تَحْتِهَا الْأَنْهَارُ ۚ ذَٰلِكَ الْفَوْزُ الْكَبِيرُ"},{"verseKey":"85:12","surah":85,"ayah":12,"text":"إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ"},{"verseKey":"85:13","surah":85,"ayah":13,"text":"إِنَّهُ هُوَ يُبْدِئُ وَيُعِيدُ"},{"verseKey":"85:14","surah":85,"ayah":14,"text":"وَهُوَ الْغَفُورُ الْوَدُودُ"},{"verseKey":"85:15","surah":85,"ayah":15,"text":"ذُو الْعَرْشِ الْمَجِيدُ"},{"verseKey":"85:16","surah":85,"ayah":16,"text":"فَعَّالٌ لِمَا يُرِيدُ"},{"verseKey":"85:17","surah":85,"ayah":17,"text":"هَلْ أَتَاكَ حَدِيثُ الْجُنُودِ"},{"verseKey":"85:18","surah":85,"ayah":18,"text":"فِرْعَوْنَ وَثَمُودَ"},{"verseKey":"85:19","surah":85,"ayah":19,"text":"بَلِ الَّذِينَ كَفَرُوا فِي تَكْذِيبٍ"},{"verseKey":"85:20","surah":85,"ayah":20,"text":"وَاللَّهُ مِنْ وَرَائِهِمْ مُحِيطٌ"},{"verseKey":"85:21","surah":85,"ayah":21,"text":"بَلْ هُوَ قُرْآنٌ مَجِيدٌ"},{"verseKey":"85:22","surah":85,"ayah":22,"text":"فِي لَوْحٍ مَحْفُوظٍ"}]}

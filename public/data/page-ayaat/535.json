{"pageNumber":535,"ayahs":[{"verseKey":"56:17","surah":56,"ayah":17,"text":"يَطُوفُ عَلَيْهِمْ وِلْدَانٌ مُخَلَّدُونَ"},{"verseKey":"56:18","surah":56,"ayah":18,"text":"بِأَكْوَابٍ وَأَبَارِيقَ وَكَأْسٍ مِنْ مَعِينٍ"},{"verseKey":"56:19","surah":56,"ayah":19,"text":"لَا يُصَدَّعُونَ عَنْهَا وَلَا يُنْزِفُونَ"},{"verseKey":"56:20","surah":56,"ayah":20,"text":"وَفَاكِهَةٍ مِمَّا يَتَخَيَّرُونَ"},{"verseKey":"56:21","surah":56,"ayah":21,"text":"وَلَحْمِ طَيْرٍ مِمَّا يَشْتَهُونَ"},{"verseKey":"56:22","surah":56,"ayah":22,"text":"وَحُورٌ عِينٌ"},{"verseKey":"56:23","surah":56,"ayah":23,"text":"كَأَمْثَالِ اللُّؤْلُؤِ الْمَكْنُونِ"},{"verseKey":"56:24","surah":56,"ayah":24,"text":"جَزَاءً بِمَا كَانُوا يَعْمَلُونَ"},{"verseKey":"56:25","surah":56,"ayah":25,"text":"لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا تَأْثِيمًا"},{"verseKey":"56:26","surah":56,"ayah":26,"text":"إِلَّا قِيلًا سَلَامًا سَلَامًا"},{"verseKey":"56:27","surah":56,"ayah":27,"text":"وَأَصْحَابُ الْيَمِينِ مَا أَصْحَابُ الْيَمِينِ"},{"verseKey":"56:28","surah":56,"ayah":28,"text":"فِي سِدْرٍ مَخْضُودٍ"},{"verseKey":"56:29","surah":56,"ayah":29,"text":"وَطَلْحٍ مَنْضُودٍ"},{"verseKey":"56:30","surah":56,"ayah":30,"text":"وَظِلٍّ مَمْدُودٍ"},{"verseKey":"56:31","surah":56,"ayah":31,"text":"وَمَاءٍ مَسْكُوبٍ"},{"verseKey":"56:32","surah":56,"ayah":32,"text":"وَفَاكِهَةٍ كَثِيرَةٍ"},{"verseKey":"56:33","surah":56,"ayah":33,"text":"لَا مَقْطُوعَةٍ وَلَا مَمْنُوعَةٍ"},{"verseKey":"56:34","surah":56,"ayah":34,"text":"وَفُرُشٍ مَرْفُوعَةٍ"},{"verseKey":"56:35","surah":56,"ayah":35,"text":"إِنَّا أَنْشَأْنَاهُنَّ إِنْشَاءً"},{"verseKey":"56:36","surah":56,"ayah":36,"text":"فَجَعَلْنَاهُنَّ أَبْكَارًا"},{"verseKey":"56:37","surah":56,"ayah":37,"text":"عُرُبًا أَتْرَابًا"},{"verseKey":"56:38","surah":56,"ayah":38,"text":"لِأَصْحَابِ الْيَمِينِ"},{"verseKey":"56:39","surah":56,"ayah":39,"text":"ثُلَّةٌ مِنَ الْأَوَّلِينَ"},{"verseKey":"56:40","surah":56,"ayah":40,"text":"وَثُلَّةٌ مِنَ الْآخِرِينَ"},{"verseKey":"56:41","surah":56,"ayah":41,"text":"وَأَصْحَابُ الشِّمَالِ مَا أَصْحَابُ الشِّمَالِ"},{"verseKey":"56:42","surah":56,"ayah":42,"text":"فِي سَمُومٍ وَحَمِيمٍ"},{"verseKey":"56:43","surah":56,"ayah":43,"text":"وَظِلٍّ مِنْ يَحْمُومٍ"},{"verseKey":"56:44","surah":56,"ayah":44,"text":"لَا بَارِدٍ وَلَا كَرِيمٍ"},{"verseKey":"56:45","surah":56,"ayah":45,"text":"إِنَّهُمْ كَانُوا قَبْلَ ذَٰلِكَ مُتْرَفِينَ"},{"verseKey":"56:46","surah":56,"ayah":46,"text":"وَكَانُوا يُصِرُّونَ عَلَى الْحِنْثِ الْعَظِيمِ"},{"verseKey":"56:47","surah":56,"ayah":47,"text":"وَكَانُوا يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَامًا أَإِنَّا لَمَبْعُوثُونَ"},{"verseKey":"56:48","surah":56,"ayah":48,"text":"أَوَآبَاؤُنَا الْأَوَّلُونَ"},{"verseKey":"56:49","surah":56,"ayah":49,"text":"قُلْ إِنَّ الْأَوَّلِينَ وَالْآخِرِينَ"},{"verseKey":"56:50","surah":56,"ayah":50,"text":"لَمَجْمُوعُونَ إِلَىٰ مِيقَاتِ يَوْمٍ مَعْلُومٍ"}]}

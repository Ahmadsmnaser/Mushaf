{"pageNumber":372,"ayahs":[{"verseKey":"26:112","surah":26,"ayah":112,"text":"قَالَ وَمَا عِلْمِي بِمَا كَانُوا يَعْمَلُونَ"},{"verseKey":"26:113","surah":26,"ayah":113,"text":"إِنْ حِسَابُهُمْ إِلَّا عَلَىٰ رَبِّي ۖ لَوْ تَشْعُرُونَ"},{"verseKey":"26:114","surah":26,"ayah":114,"text":"وَمَا أَنَا بِطَارِدِ الْمُؤْمِنِينَ"},{"verseKey":"26:115","surah":26,"ayah":115,"text":"إِنْ أَنَا إِلَّا نَذِيرٌ مُبِينٌ"},{"verseKey":"26:116","surah":26,"ayah":116,"text":"قَالُوا لَئِنْ لَمْ تَنْتَهِ يَا نُوحُ لَتَكُونَنَّ مِنَ الْمَرْجُومِينَ"},{"verseKey":"26:117","surah":26,"ayah":117,"text":"قَالَ رَبِّ إِنَّ قَوْمِي كَذَّبُونِ"},{"verseKey":"26:118","surah":26,"ayah":118,"text":"فَافْتَحْ بَيْنِي وَبَيْنَهُمْ فَتْحًا وَنَجِّنِي وَمَنْ مَعِيَ مِنَ الْمُؤْمِنِينَ"},{"verseKey":"26:119","surah":26,"ayah":119,"text":"فَأَنْجَيْنَاهُ وَمَنْ مَعَهُ فِي الْفُلْكِ الْمَشْحُونِ"},{"verseKey":"26:120","surah":26,"ayah":120,"text":"ثُمَّ أَغْرَقْنَا بَعْدُ الْبَاقِينَ"},{"verseKey":"26:121","surah":26,"ayah":121,"text":"إِنَّ فِي ذَٰلِكَ لَآيَةً ۖ وَمَا كَانَ أَكْثَرُهُمْ مُؤْمِنِينَ"},{"verseKey":"26:122","surah":26,"ayah":122,"text":"وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ الرَّحِيمُ"},{"verseKey":"26:123","surah":26,"ayah":123,"text":"كَذَّبَتْ عَادٌ الْمُرْسَلِينَ"},{"verseKey":"26:124","surah":26,"ayah":124,"text":"إِذْ قَالَ لَهُمْ أَخُوهُمْ هُودٌ أَلَا تَتَّقُونَ"},{"verseKey":"26:125","surah":26,"ayah":125,"text":"إِنِّي لَكُمْ رَسُولٌ أَمِينٌ"},{"verseKey":"26:126","surah":26,"ayah":126,"text":"فَاتَّقُوا اللَّهَ وَأَطِيعُونِ"},{"verseKey":"26:127","surah":26,"ayah":127,"text":"وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِيَ إِلَّا عَلَىٰ رَبِّ الْعَالَمِينَ"},{"verseKey":"26:128","surah":26,"ayah":128,"text":"أَتَبْنُونَ بِكُلِّ رِيعٍ آيَةً تَعْبَثُونَ"},{"verseKey":"26:129","surah":26,"ayah":129,"text":"وَتَتَّخِذُونَ مَصَانِعَ لَعَلَّكُمْ تَخْلُدُونَ"},{"verseKey":"26:130","surah":26,"ayah":130,"text":"وَإِذَا بَطَشْتُمْ بَطَشْتُمْ جَبَّارِينَ"},{"verseKey":"26:131","surah":26,"ayah":131,"text":"فَاتَّقُوا اللَّهَ وَأَطِيعُونِ"},{"verseKey":"26:132","surah":26,"ayah":132,"text":"وَاتَّقُوا الَّذِي أَمَدَّكُمْ بِمَا تَعْلَمُونَ"},{"verseKey":"26:133","surah":26,"ayah":133,"text":"أَمَدَّكُمْ بِأَنْعَامٍ وَبَنِينَ"},{"verseKey":"26:134","surah":26,"ayah":134,"text":"وَجَنَّاتٍ وَعُيُونٍ"},{"verseKey":"26:135","surah":26,"ayah":135,"text":"إِنِّي أَخَافُ عَلَيْكُمْ عَذَابَ يَوْمٍ عَظِيمٍ"},{"verseKey":"26:136","surah":26,"ayah":136,"text":"قَالُوا سَوَاءٌ عَلَيْنَا أَوَعَظْتَ أَمْ لَمْ تَكُنْ مِنَ الْوَاعِظِينَ"}]}

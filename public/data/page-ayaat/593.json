{"pageNumber":593,"ayahs":[{"verseKey":"88:23","surah":88,"ayah":23,"text":"إِلَّا مَنْ تَوَلَّىٰ وَكَفَرَ"},{"verseKey":"88:24","surah":88,"ayah":24,"text":"فَيُعَذِّبُهُ اللَّهُ الْعَذَابَ الْأَكْبَرَ"},{"verseKey":"88:25","surah":88,"ayah":25,"text":"إِنَّ إِلَيْنَا إِيَابَهُمْ"},{"verseKey":"88:26","surah":88,"ayah":26,"text":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُمْ"},{"verseKey":"89:1","surah":89,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالْفَجْرِ"},{"verseKey":"89:2","surah":89,"ayah":2,"text":"وَلَيَالٍ عَشْرٍ"},{"verseKey":"89:3","surah":89,"ayah":3,"text":"وَالشَّفْعِ وَالْوَتْرِ"},{"verseKey":"89:4","surah":89,"ayah":4,"text":"وَاللَّيْلِ إِذَا يَسْرِ"},{"verseKey":"89:5","surah":89,"ayah":5,"text":"هَلْ فِي ذَٰلِكَ قَسَمٌ لِذِي حِجْرٍ"},{"verseKey":"89:6","surah":89,"ayah":6,"text":"أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ"},{"verseKey":"89:7","surah":89,"ayah":7,"text":"إِرَمَ ذَاتِ الْعِمَادِ"},{"verseKey":"89:8","surah":89,"ayah":8,"text":"الَّتِي لَمْ يُخْلَقْ مِثْلُهَا فِي الْبِلَادِ"},{"verseKey":"89:9","surah":89,"ayah":9,"text":"وَثَمُودَ الَّذِينَ جَابُوا الصَّخْرَ بِالْوَادِ"},{"verseKey":"89:10","surah":89,"ayah":10,"text":"وَفِرْعَوْنَ ذِي الْأَوْتَادِ"},{"verseKey":"89:11","surah":89,"ayah":11,"text":"الَّذِينَ طَغَوْا فِي الْبِلَادِ"},{"verseKey":"89:12","surah":89,"ayah":12,"text":"فَأَكْثَرُوا فِيهَا الْفَسَادَ"},{"verseKey":"89:13","surah":89,"ayah":13,"text":"فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ"},{"verseKey":"89:14","surah":89,"ayah":14,"text":"إِنَّ رَبَّكَ لَبِالْمِرْصَادِ"},{"verseKey":"89:15","surah":89,"ayah":15,"text":"فَأَمَّا الْإِنْسَانُ إِذَا مَا ابْتَلَاهُ رَبُّهُ فَأَكْرَمَهُ وَنَعَّمَهُ فَيَقُولُ رَبِّي أَكْرَمَنِ"},{"verseKey":"89:16","surah":89,"ayah":16,"text":"وَأَمَّا إِذَا مَا ابْتَلَاهُ فَقَدَرَ عَلَيْهِ رِزْقَهُ فَيَقُولُ رَبِّي أَهَانَنِ"},{"verseKey":"89:17","surah":89,"ayah":17,"text":"كَلَّا ۖ بَلْ لَا تُكْرِمُونَ الْيَتِيمَ"},{"verseKey":"89:18","surah":89,"ayah":18,"text":"وَلَا تَحَاضُّونَ عَلَىٰ طَعَامِ الْمِسْكِينِ"},{"verseKey":"89:19","surah":89,"ayah":19,"text":"وَتَأْكُلُونَ التُّرَاثَ أَكْلًا لَمًّا"},{"verseKey":"89:20","surah":89,"ayah":20,"text":"وَتُحِبُّونَ الْمَالَ حُبًّا جَمًّا"},{"verseKey":"89:21","surah":89,"ayah":21,"text":"كَلَّا إِذَا دُكَّتِ الْأَرْضُ دَكًّا دَكًّا"},{"verseKey":"89:22","surah":89,"ayah":22,"text":"وَجَاءَ رَبُّكَ وَالْمَلَكُ صَفًّا صَفًّا"}]}

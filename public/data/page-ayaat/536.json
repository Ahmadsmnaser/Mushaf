{"pageNumber":536,"ayahs":[{"verseKey":"56:51","surah":56,"ayah":51,"text":"ثُمَّ إِنَّكُمْ أَيُّهَا الضَّالُّونَ الْمُكَذِّبُونَ"},{"verseKey":"56:52","surah":56,"ayah":52,"text":"لَآكِلُونَ مِنْ شَجَرٍ مِنْ زَقُّومٍ"},{"verseKey":"56:53","surah":56,"ayah":53,"text":"فَمَالِئُونَ مِنْهَا الْبُطُونَ"},{"verseKey":"56:54","surah":56,"ayah":54,"text":"فَشَارِبُونَ عَلَيْهِ مِنَ الْحَمِيمِ"},{"verseKey":"56:55","surah":56,"ayah":55,"text":"فَشَارِبُونَ شُرْبَ الْهِيمِ"},{"verseKey":"56:56","surah":56,"ayah":56,"text":"هَٰذَا نُزُلُهُمْ يَوْمَ الدِّينِ"},{"verseKey":"56:57","surah":56,"ayah":57,"text":"نَحْنُ خَلَقْنَاكُمْ فَلَوْلَا تُصَدِّقُونَ"},{"verseKey":"56:58","surah":56,"ayah":58,"text":"أَفَرَأَيْتُمْ مَا تُمْنُونَ"},{"verseKey":"56:59","surah":56,"ayah":59,"text":"أَأَنْتُمْ تَخْلُقُونَهُ أَمْ نَحْنُ الْخَالِقُونَ"},{"verseKey":"56:60","surah":56,"ayah":60,"text":"نَحْنُ قَدَّرْنَا بَيْنَكُمُ الْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ"},{"verseKey":"56:61","surah":56,"ayah":61,"text":"عَلَىٰ أَنْ نُبَدِّلَ أَمْثَالَكُمْ وَنُنْشِئَكُمْ فِي مَا لَا تَعْلَمُونَ"},{"verseKey":"56:62","surah":56,"ayah":62,"text":"وَلَقَدْ عَلِمْتُمُ النَّشْأَةَ الْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ"},{"verseKey":"56:63","surah":56,"ayah":63,"text":"أَفَرَأَيْتُمْ مَا تَحْرُثُونَ"},{"verseKey":"56:64","surah":56,"ayah":64,"text":"أَأَنْتُمْ تَزْرَعُونَهُ أَمْ نَحْنُ الزَّارِعُونَ"},{"verseKey":"56:65","surah":56,"ayah":65,"text":"لَوْ نَشَاءُ لَجَعَلْنَاهُ حُطَامًا فَظَلْتُمْ تَفَكَّهُونَ"},{"verseKey":"56:66","surah":56,"ayah":66,"text":"إِنَّا لَمُغْرَمُونَ"},{"verseKey":"56:67","surah":56,"ayah":67,"text":"بَلْ نَحْنُ مَحْرُومُونَ"},{"verseKey":"56:68","surah":56,"ayah":68,"text":"أَفَرَأَيْتُمُ الْمَاءَ الَّذِي تَشْرَبُونَ"},{"verseKey":"56:69","surah":56,"ayah":69,"text":"أَأَنْتُمْ أَنْزَلْتُمُوهُ مِنَ الْمُزْنِ أَمْ نَحْنُ الْمُنْزِلُونَ"},{"verseKey":"56:70","surah":56,"ayah":70,"text":"لَوْ نَشَاءُ جَعَلْنَاهُ أُجَاجًا فَلَوْلَا تَشْكُرُونَ"},{"verseKey":"56:71","surah":56,"ayah":71,"text":"أَفَرَأَيْتُمُ النَّارَ الَّتِي تُورُونَ"},{"verseKey":"56:72","surah":56,"ayah":72,"text":"أَأَنْتُمْ أَنْشَأْتُمْ شَجَرَتَهَا أَمْ نَحْنُ الْمُنْشِئُونَ"},{"verseKey":"56:73","surah":56,"ayah":73,"text":"نَحْنُ جَعَلْنَاهَا تَذْكِرَةً وَمَتَاعًا لِلْمُقْوِينَ"},{"verseKey":"56:74","surah":56,"ayah":74,"text":"فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ"},{"verseKey":"56:75","surah":56,"ayah":75,"text":"۞ فَلَا أُقْسِمُ بِمَوَاقِعِ النُّجُومِ"},{"verseKey":"56:76","surah":56,"ayah":76,"text":"وَإِنَّهُ لَقَسَمٌ لَوْ تَعْلَمُونَ عَظِيمٌ"}]}

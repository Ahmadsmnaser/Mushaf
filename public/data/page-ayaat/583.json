{"pageNumber":583,"ayahs":[{"verseKey":"78:31","surah":78,"ayah":31,"text":"إِنَّ لِلْمُتَّقِينَ مَفَازًا"},{"verseKey":"78:32","surah":78,"ayah":32,"text":"حَدَائِقَ وَأَعْنَابًا"},{"verseKey":"78:33","surah":78,"ayah":33,"text":"وَكَوَاعِبَ أَتْرَابًا"},{"verseKey":"78:34","surah":78,"ayah":34,"text":"وَكَأْسًا دِهَاقًا"},{"verseKey":"78:35","surah":78,"ayah":35,"text":"لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّابًا"},{"verseKey":"78:36","surah":78,"ayah":36,"text":"جَزَاءً مِنْ رَبِّكَ عَطَاءً حِسَابًا"},{"verseKey":"78:37","surah":78,"ayah":37,"text":"رَبِّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا الرَّحْمَٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًا"},{"verseKey":"78:38","surah":78,"ayah":38,"text":"يَوْمَ يَقُومُ الرُّوحُ وَالْمَلَائِكَةُ صَفًّا ۖ لَا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ الرَّحْمَٰنُ وَقَالَ صَوَابًا"},{"verseKey":"78:39","surah":78,"ayah":39,"text":"ذَٰلِكَ الْيَوْمُ الْحَقُّ ۖ فَمَنْ شَاءَ اتَّخَذَ إِلَىٰ رَبِّهِ مَآبًا"},{"verseKey":"78:40","surah":78,"ayah":40,"text":"إِنَّا أَنْذَرْنَاكُمْ عَذَابًا قَرِيبًا يَوْمَ يَنْظُرُ الْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ الْكَافِرُ يَا لَيْتَنِي كُنْتُ تُرَابًا"},{"verseKey":"79:1","surah":79,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالنَّازِعَاتِ غَرْقًا"},{"verseKey":"79:2","surah":79,"ayah":2,"text":"وَالنَّاشِطَاتِ نَشْطًا"},{"verseKey":"79:3","surah":79,"ayah":3,"text":"وَالسَّابِحَاتِ سَبْحًا"},{"verseKey":"79:4","surah":79,"ayah":4,"text":"فَالسَّابِقَاتِ سَبْقًا"},{"verseKey":"79:5","surah":79,"ayah":5,"text":"فَالْمُدَبِّرَاتِ أَمْرًا"},{"verseKey":"79:6","surah":79,"ayah":6,"text":"يَوْمَ تَرْجُفُ الرَّاجِفَةُ"},{"verseKey":"79:7","surah":79,"ayah":7,"text":"تَتْبَعُهَا الرَّادِفَةُ"},{"verseKey":"79:8","surah":79,"ayah":8,"text":"قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ"},{"verseKey":"79:9","surah":79,"ayah":9,"text":"أَبْصَارُهَا خَاشِعَةٌ"},{"verseKey":"79:10","surah":79,"ayah":10,"text":"يَقُولُونَ أَإِنَّا لَمَرْدُودُونَ فِي الْحَافِرَةِ"},{"verseKey":"79:11","surah":79,"ayah":11,"text":"أَإِذَا كُنَّا عِظَامًا نَخِرَةً"},{"verseKey":"79:12","surah":79,"ayah":12,"text":"قَالُوا تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ"},{"verseKey":"79:13","surah":79,"ayah":13,"text":"فَإِنَّمَا هِيَ زَجْرَةٌ وَاحِدَةٌ"},{"verseKey":"79:14","surah":79,"ayah":14,"text":"فَإِذَا هُمْ بِالسَّاهِرَةِ"},{"verseKey":"79:15","surah":79,"ayah":15,"text":"هَلْ أَتَاكَ حَدِيثُ مُوسَىٰ"},{"verseKey":"79:16","surah":79,"ayah":16,"text":"إِذْ نَادَاهُ رَبُّهُ بِالْوَادِ الْمُقَدَّسِ طُوًى"}]}

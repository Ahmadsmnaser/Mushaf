{"pageNumber":595,"ayahs":[{"verseKey":"90:19","surah":90,"ayah":19,"text":"وَالَّذِينَ كَفَرُوا بِآيَاتِنَا هُمْ أَصْحَابُ الْمَشْأَمَةِ"},{"verseKey":"90:20","surah":90,"ayah":20,"text":"عَلَيْهِمْ نَارٌ مُؤْصَدَةٌ"},{"verseKey":"91:1","surah":91,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالشَّمْسِ وَضُحَاهَا"},{"verseKey":"91:2","surah":91,"ayah":2,"text":"وَالْقَمَرِ إِذَا تَلَاهَا"},{"verseKey":"91:3","surah":91,"ayah":3,"text":"وَالنَّهَارِ إِذَا جَلَّاهَا"},{"verseKey":"91:4","surah":91,"ayah":4,"text":"وَاللَّيْلِ إِذَا يَغْشَاهَا"},{"verseKey":"91:5","surah":91,"ayah":5,"text":"وَالسَّمَاءِ وَمَا بَنَاهَا"},{"verseKey":"91:6","surah":91,"ayah":6,"text":"وَالْأَرْضِ وَمَا طَحَاهَا"},{"verseKey":"91:7","surah":91,"ayah":7,"text":"وَنَفْسٍ وَمَا سَوَّاهَا"},{"verseKey":"91:8","surah":91,"ayah":8,"text":"فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَاهَا"},{"verseKey":"91:9","surah":91,"ayah":9,"text":"قَدْ أَفْلَحَ مَنْ زَكَّاهَا"},{"verseKey":"91:10","surah":91,"ayah":10,"text":"وَقَدْ خَابَ مَنْ دَسَّاهَا"},{"verseKey":"91:11","surah":91,"ayah":11,"text":"كَذَّبَتْ ثَمُودُ بِطَغْوَاهَا"},{"verseKey":"91:12","surah":91,"ayah":12,"text":"إِذِ انْبَعَثَ أَشْقَاهَا"},{"verseKey":"91:13","surah":91,"ayah":13,"text":"فَقَالَ لَهُمْ رَسُولُ اللَّهِ نَاقَةَ اللَّهِ وَسُقْيَاهَا"},{"verseKey":"91:14","surah":91,"ayah":14,"text":"فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُمْ بِذَنْبِهِمْ فَسَوَّاهَا"},{"verseKey":"91:15","surah":91,"ayah":15,"text":"وَلَا يَخَافُ عُقْبَاهَا"},{"verseKey":"92:1","surah":92,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَاللَّيْلِ إِذَا يَغْشَىٰ"},{"verseKey":"92:2","surah":92,"ayah":2,"text":"وَالنَّهَارِ إِذَا تَجَلَّىٰ"},{"verseKey":"92:3","surah":92,"ayah":3,"text":"وَمَا خَلَقَ الذَّكَرَ وَالْأُنْثَىٰ"},{"verseKey":"92:4","surah":92,"ayah":4,"text":"إِنَّ سَعْيَكُمْ لَشَتَّىٰ"},{"verseKey":"92:5","surah":92,"ayah":5,"text":"فَأَمَّا مَنْ أَعْطَىٰ وَاتَّقَىٰ"},{"verseKey":"92:6","surah":92,"ayah":6,"text":"وَصَدَّقَ بِالْحُسْنَىٰ"},{"verseKey":"92:7","surah":92,"ayah":7,"text":"فَسَنُيَسِّرُهُ لِلْيُسْرَىٰ"},{"verseKey":"92:8","surah":92,"ayah":8,"text":"وَأَمَّا مَنْ بَخِلَ وَاسْتَغْنَىٰ"},{"verseKey":"92:9","surah":92,"ayah":9,"text":"وَكَذَّبَ بِالْحُسْنَىٰ"}]}

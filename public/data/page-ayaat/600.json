{"pageNumber":600,"ayahs":[{"verseKey":"100:6","surah":100,"ayah":6,"text":"إِنَّ الْإِنْسَانَ لِرَبِّهِ لَكَنُودٌ"},{"verseKey":"100:7","surah":100,"ayah":7,"text":"وَإِنَّهُ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ"},{"verseKey":"100:8","surah":100,"ayah":8,"text":"وَإِنَّهُ لِحُبِّ الْخَيْرِ لَشَدِيدٌ"},{"verseKey":"100:9","surah":100,"ayah":9,"text":"۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِي الْقُبُورِ"},{"verseKey":"100:10","surah":100,"ayah":10,"text":"وَحُصِّلَ مَا فِي الصُّدُورِ"},{"verseKey":"100:11","surah":100,"ayah":11,"text":"إِنَّ رَبَّهُمْ بِهِمْ يَوْمَئِذٍ لَخَبِيرٌ"},{"verseKey":"101:1","surah":101,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ الْقَارِعَةُ"},{"verseKey":"101:2","surah":101,"ayah":2,"text":"مَا الْقَارِعَةُ"},{"verseKey":"101:3","surah":101,"ayah":3,"text":"وَمَا أَدْرَاكَ مَا الْقَارِعَةُ"},{"verseKey":"101:4","surah":101,"ayah":4,"text":"يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ"},{"verseKey":"101:5","surah":101,"ayah":5,"text":"وَتَكُونُ الْجِبَالُ كَالْعِهْنِ الْمَنْفُوشِ"},{"verseKey":"101:6","surah":101,"ayah":6,"text":"فَأَمَّا مَنْ ثَقُلَتْ مَوَازِينُهُ"},{"verseKey":"101:7","surah":101,"ayah":7,"text":"فَهُوَ فِي عِيشَةٍ رَاضِيَةٍ"},{"verseKey":"101:8","surah":101,"ayah":8,"text":"وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ"},{"verseKey":"101:9","surah":101,"ayah":9,"text":"فَأُمُّهُ هَاوِيَةٌ"},{"verseKey":"101:10","surah":101,"ayah":10,"text":"وَمَا أَدْرَاكَ مَا هِيَهْ"},{"verseKey":"101:11","surah":101,"ayah":11,"text":"نَارٌ حَامِيَةٌ"},{"verseKey":"102:1","surah":102,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ أَلْهَاكُمُ التَّكَاثُرُ"},{"verseKey":"102:2","surah":102,"ayah":2,"text":"حَتَّىٰ زُرْتُمُ الْمَقَابِرَ"},{"verseKey":"102:3","surah":102,"ayah":3,"text":"كَلَّا سَوْفَ تَعْلَمُونَ"},{"verseKey":"102:4","surah":102,"ayah":4,"text":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ"},{"verseKey":"102:5","surah":102,"ayah":5,"text":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ الْيَقِينِ"},{"verseKey":"102:6","surah":102,"ayah":6,"text":"لَتَرَوُنَّ الْجَحِيمَ"},{"verseKey":"102:7","surah":102,"ayah":7,"text":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ الْيَقِينِ"},{"verseKey":"102:8","surah":102,"ayah":8,"text":"ثُمَّ لَتُسْأَلُنَّ يَوْمَئِذٍ عَنِ النَّعِيمِ"}]}

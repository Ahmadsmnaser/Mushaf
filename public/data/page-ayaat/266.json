{"pageNumber":266,"ayahs":[{"verseKey":"15:71","surah":15,"ayah":71,"text":"قَالَ هَٰؤُلَاءِ بَنَاتِي إِنْ كُنْتُمْ فَاعِلِينَ"},{"verseKey":"15:72","surah":15,"ayah":72,"text":"لَعَمْرُكَ إِنَّهُمْ لَفِي سَكْرَتِهِمْ يَعْمَهُونَ"},{"verseKey":"15:73","surah":15,"ayah":73,"text":"فَأَخَذَتْهُمُ الصَّيْحَةُ مُشْرِقِينَ"},{"verseKey":"15:74","surah":15,"ayah":74,"text":"فَجَعَلْنَا عَالِيَهَا سَافِلَهَا وَأَمْطَرْنَا عَلَيْهِمْ حِجَارَةً مِنْ سِجِّيلٍ"},{"verseKey":"15:75","surah":15,"ayah":75,"text":"إِنَّ فِي ذَٰلِكَ لَآيَاتٍ لِلْمُتَوَسِّمِينَ"},{"verseKey":"15:76","surah":15,"ayah":76,"text":"وَإِنَّهَا لَبِسَبِيلٍ مُقِيمٍ"},{"verseKey":"15:77","surah":15,"ayah":77,"text":"إِنَّ فِي ذَٰلِكَ لَآيَةً لِلْمُؤْمِنِينَ"},{"verseKey":"15:78","surah":15,"ayah":78,"text":"وَإِنْ كَانَ أَصْحَابُ الْأَيْكَةِ لَظَالِمِينَ"},{"verseKey":"15:79","surah":15,"ayah":79,"text":"فَانْتَقَمْنَا مِنْهُمْ وَإِنَّهُمَا لَبِإِمَامٍ مُبِينٍ"},{"verseKey":"15:80","surah":15,"ayah":80,"text":"وَلَقَدْ كَذَّبَ أَصْحَابُ الْحِجْرِ الْمُرْسَلِينَ"},{"verseKey":"15:81","surah":15,"ayah":81,"text":"وَآتَيْنَاهُمْ آيَاتِنَا فَكَانُوا عَنْهَا مُعْرِضِينَ"},{"verseKey":"15:82","surah":15,"ayah":82,"text":"وَكَانُوا يَنْحِتُونَ مِنَ الْجِبَالِ بُيُوتًا آمِنِينَ"},{"verseKey":"15:83","surah":15,"ayah":83,"text":"فَأَخَذَتْهُمُ الصَّيْحَةُ مُصْبِحِينَ"},{"verseKey":"15:84","surah":15,"ayah":84,"text":"فَمَا أَغْنَىٰ عَنْهُمْ مَا كَانُوا يَكْسِبُونَ"},{"verseKey":"15:85","surah":15,"ayah":85,"text":"وَمَا خَلَقْنَا السَّمَاوَاتِ وَالْأَرْضَ وَمَا بَيْنَهُمَا إِلَّا بِالْحَقِّ ۗ وَإِنَّ السَّاعَةَ لَآتِيَةٌ ۖ فَاصْفَحِ الصَّفْحَ الْجَمِيلَ"},{"verseKey":"15:86","surah":15,"ayah":86,"text":"إِنَّ رَبَّكَ هُوَ الْخَلَّاقُ الْعَلِيمُ"},{"verseKey":"15:87","surah":15,"ayah":87,"text":"وَلَقَدْ آتَيْنَاكَ سَبْعًا مِنَ الْمَثَانِي وَالْقُرْآنَ الْعَظِيمَ"},{"verseKey":"15:88","surah":15,"ayah":88,"text":"لَا تَمُدَّنَّ عَيْنَيْكَ إِلَىٰ مَا مَتَّعْنَا بِهِ أَزْوَاجًا مِنْهُمْ وَلَا تَحْزَنْ عَلَيْهِمْ وَاخْفِضْ جَنَاحَكَ لِلْمُؤْمِنِينَ"},{"verseKey":"15:89","surah":15,"ayah":89,"text":"وَقُلْ إِنِّي أَنَا النَّذِيرُ الْمُبِينُ"},{"verseKey":"15:90","surah":15,"ayah":90,"text":"كَمَا أَنْزَلْنَا عَلَى الْمُقْتَسِمِينَ"}]}

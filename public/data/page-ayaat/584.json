{"pageNumber":584,"ayahs":[{"verseKey":"79:17","surah":79,"ayah":17,"text":"اذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُ طَغَىٰ"},{"verseKey":"79:18","surah":79,"ayah":18,"text":"فَقُلْ هَلْ لَكَ إِلَىٰ أَنْ تَزَكَّىٰ"},{"verseKey":"79:19","surah":79,"ayah":19,"text":"وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ"},{"verseKey":"79:20","surah":79,"ayah":20,"text":"فَأَرَاهُ الْآيَةَ الْكُبْرَىٰ"},{"verseKey":"79:21","surah":79,"ayah":21,"text":"فَكَذَّبَ وَعَصَىٰ"},{"verseKey":"79:22","surah":79,"ayah":22,"text":"ثُمَّ أَدْبَرَ يَسْعَىٰ"},{"verseKey":"79:23","surah":79,"ayah":23,"text":"فَحَشَرَ فَنَادَىٰ"},{"verseKey":"79:24","surah":79,"ayah":24,"text":"فَقَالَ أَنَا رَبُّكُمُ الْأَعْلَىٰ"},{"verseKey":"79:25","surah":79,"ayah":25,"text":"فَأَخَذَهُ اللَّهُ نَكَالَ الْآخِرَةِ وَالْأُولَىٰ"},{"verseKey":"79:26","surah":79,"ayah":26,"text":"إِنَّ فِي ذَٰلِكَ لَعِبْرَةً لِمَنْ يَخْشَىٰ"},{"verseKey":"79:27","surah":79,"ayah":27,"text":"أَأَنْتُمْ أَشَدُّ خَلْقًا أَمِ السَّمَاءُ ۚ بَنَاهَا"},{"verseKey":"79:28","surah":79,"ayah":28,"text":"رَفَعَ سَمْكَهَا فَسَوَّاهَا"},{"verseKey":"79:29","surah":79,"ayah":29,"text":"وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَاهَا"},{"verseKey":"79:30","surah":79,"ayah":30,"text":"وَالْأَرْضَ بَعْدَ ذَٰلِكَ دَحَاهَا"},{"verseKey":"79:31","surah":79,"ayah":31,"text":"أَخْرَجَ مِنْهَا مَاءَهَا وَمَرْعَاهَا"},{"verseKey":"79:32","surah":79,"ayah":32,"text":"وَالْجِبَالَ أَرْسَاهَا"},{"verseKey":"79:33","surah":79,"ayah":33,"text":"مَتَاعًا لَكُمْ وَلِأَنْعَامِكُمْ"},{"verseKey":"79:34","surah":79,"ayah":34,"text":"فَإِذَا جَاءَتِ الطَّامَّةُ الْكُبْرَىٰ"},{"verseKey":"79:35","surah":79,"ayah":35,"text":"يَوْمَ يَتَذَكَّرُ الْإِنْسَانُ مَا سَعَىٰ"},{"verseKey":"79:36","surah":79,"ayah":36,"text":"وَبُرِّزَتِ الْجَحِيمُ لِمَنْ يَرَىٰ"},{"verseKey":"79:37","surah":79,"ayah":37,"text":"فَأَمَّا مَنْ طَغَىٰ"},{"verseKey":"79:38","surah":79,"ayah":38,"text":"وَآثَرَ الْحَيَاةَ الدُّنْيَا"},{"verseKey":"79:39","surah":79,"ayah":39,"text":"فَإِنَّ الْجَحِيمَ هِيَ الْمَأْوَىٰ"},{"verseKey":"79:40","surah":79,"ayah":40,"text":"وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِ وَنَهَى النَّفْسَ عَنِ الْهَوَىٰ"},{"verseKey":"79:41","surah":79,"ayah":41,"text":"فَإِنَّ الْجَنَّةَ هِيَ الْمَأْوَىٰ"},{"verseKey":"79:42","surah":79,"ayah":42,"text":"يَسْأَلُونَكَ عَنِ السَّاعَةِ أَيَّانَ مُرْسَاهَا"},{"verseKey":"79:43","surah":79,"ayah":43,"text":"فِيمَ أَنْتَ مِنْ ذِكْرَاهَا"},{"verseKey":"79:44","surah":79,"ayah":44,"text":"إِلَىٰ رَبِّكَ مُنْتَهَاهَا"},{"verseKey":"79:45","surah":79,"ayah":45,"text":"إِنَّمَا أَنْتَ مُنْذِرُ مَنْ يَخْشَاهَا"},{"verseKey":"79:46","surah":79,"ayah":46,"text":"كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوا إِلَّا عَشِيَّةً أَوْ ضُحَاهَا"}]}

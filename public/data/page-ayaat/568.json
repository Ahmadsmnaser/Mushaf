{"pageNumber":568,"ayahs":[{"verseKey":"69:36","surah":69,"ayah":36,"text":"وَلَا طَعَامٌ إِلَّا مِنْ غِسْلِينٍ"},{"verseKey":"69:37","surah":69,"ayah":37,"text":"لَا يَأْكُلُهُ إِلَّا الْخَاطِئُونَ"},{"verseKey":"69:38","surah":69,"ayah":38,"text":"فَلَا أُقْسِمُ بِمَا تُبْصِرُونَ"},{"verseKey":"69:39","surah":69,"ayah":39,"text":"وَمَا لَا تُبْصِرُونَ"},{"verseKey":"69:40","surah":69,"ayah":40,"text":"إِنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ"},{"verseKey":"69:41","surah":69,"ayah":41,"text":"وَمَا هُوَ بِقَوْلِ شَاعِرٍ ۚ قَلِيلًا مَا تُؤْمِنُونَ"},{"verseKey":"69:42","surah":69,"ayah":42,"text":"وَلَا بِقَوْلِ كَاهِنٍ ۚ قَلِيلًا مَا تَذَكَّرُونَ"},{"verseKey":"69:43","surah":69,"ayah":43,"text":"تَنْزِيلٌ مِنْ رَبِّ الْعَالَمِينَ"},{"verseKey":"69:44","surah":69,"ayah":44,"text":"وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ الْأَقَاوِيلِ"},{"verseKey":"69:45","surah":69,"ayah":45,"text":"لَأَخَذْنَا مِنْهُ بِالْيَمِينِ"},{"verseKey":"69:46","surah":69,"ayah":46,"text":"ثُمَّ لَقَطَعْنَا مِنْهُ الْوَتِينَ"},{"verseKey":"69:47","surah":69,"ayah":47,"text":"فَمَا مِنْكُمْ مِنْ أَحَدٍ عَنْهُ حَاجِزِينَ"},{"verseKey":"69:48","surah":69,"ayah":48,"text":"وَإِنَّهُ لَتَذْكِرَةٌ لِلْمُتَّقِينَ"},{"verseKey":"69:49","surah":69,"ayah":49,"text":"وَإِنَّا لَنَعْلَمُ أَنَّ مِنْكُمْ مُكَذِّبِينَ"},{"verseKey":"69:50","surah":69,"ayah":50,"text":"وَإِنَّهُ لَحَسْرَةٌ عَلَى الْكَافِرِينَ"},{"verseKey":"69:51","surah":69,"ayah":51,"text":"وَإِنَّهُ لَحَقُّ الْيَقِينِ"},{"verseKey":"69:52","surah":69,"ayah":52,"text":"فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ"},{"verseKey":"70:1","surah":70,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ سَأَلَ سَائِلٌ بِعَذَابٍ وَاقِعٍ"},{"verseKey":"70:2","surah":70,"ayah":2,"text":"لِلْكَافِرِينَ لَيْسَ لَهُ دَافِعٌ"},{"verseKey":"70:3","surah":70,"ayah":3,"text":"مِنَ اللَّهِ ذِي الْمَعَارِجِ"},{"verseKey":"70:4","surah":70,"ayah":4,"text":"تَعْرُجُ الْمَلَائِكَةُ وَالرُّوحُ إِلَيْهِ فِي يَوْمٍ كَانَ مِقْدَارُهُ خَمْسِينَ أَلْفَ سَنَةٍ"},{"verseKey":"70:5","surah":70,"ayah":5,"text":"فَاصْبِرْ صَبْرًا جَمِيلًا"},{"verseKey":"70:6","surah":70,"ayah":6,"text":"إِنَّهُمْ يَرَوْنَهُ بَعِيدًا"},{"verseKey":"70:7","surah":70,"ayah":7,"text":"وَنَرَاهُ قَرِيبًا"},{"verseKey":"70:8","surah":70,"ayah":8,"text":"يَوْمَ تَكُونُ السَّمَاءُ كَالْمُهْلِ"},{"verseKey":"70:9","surah":70,"ayah":9,"text":"وَتَكُونُ الْجِبَالُ كَالْعِهْنِ"},{"verseKey":"70:10","surah":70,"ayah":10,"text":"وَلَا يَسْأَلُ حَمِيمٌ حَمِيمًا"}]}

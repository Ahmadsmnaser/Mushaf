{"pageNumber":450,"ayahs":[{"verseKey":"37:103","surah":37,"ayah":103,"text":"فَلَمَّا أَسْلَمَا وَتَلَّهُ لِلْجَبِينِ"},{"verseKey":"37:104","surah":37,"ayah":104,"text":"وَنَادَيْنَاهُ أَنْ يَا إِبْرَاهِيمُ"},{"verseKey":"37:105","surah":37,"ayah":105,"text":"قَدْ صَدَّقْتَ الرُّؤْيَا ۚ إِنَّا كَذَٰلِكَ نَجْزِي الْمُحْسِنِينَ"},{"verseKey":"37:106","surah":37,"ayah":106,"text":"إِنَّ هَٰذَا لَهُوَ الْبَلَاءُ الْمُبِينُ"},{"verseKey":"37:107","surah":37,"ayah":107,"text":"وَفَدَيْنَاهُ بِذِبْحٍ عَظِيمٍ"},{"verseKey":"37:108","surah":37,"ayah":108,"text":"وَتَرَكْنَا عَلَيْهِ فِي الْآخِرِينَ"},{"verseKey":"37:109","surah":37,"ayah":109,"text":"سَلَامٌ عَلَىٰ إِبْرَاهِيمَ"},{"verseKey":"37:110","surah":37,"ayah":110,"text":"كَذَٰلِكَ نَجْزِي الْمُحْسِنِينَ"},{"verseKey":"37:111","surah":37,"ayah":111,"text":"إِنَّهُ مِنْ عِبَادِنَا الْمُؤْمِنِينَ"},{"verseKey":"37:112","surah":37,"ayah":112,"text":"وَبَشَّرْنَاهُ بِإِسْحَاقَ نَبِيًّا مِنَ الصَّالِحِينَ"},{"verseKey":"37:113","surah":37,"ayah":113,"text":"وَبَارَكْنَا عَلَيْهِ وَعَلَىٰ إِسْحَاقَ ۚ وَمِنْ ذُرِّيَّتِهِمَا مُحْسِنٌ وَظَالِمٌ لِنَفْسِهِ مُبِينٌ"},{"verseKey":"37:114","surah":37,"ayah":114,"text":"وَلَقَدْ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَارُونَ"},{"verseKey":"37:115","surah":37,"ayah":115,"text":"وَنَجَّيْنَاهُمَا وَقَوْمَهُمَا مِنَ الْكَرْبِ الْعَظِيمِ"},{"verseKey":"37:116","surah":37,"ayah":116,"text":"وَنَصَرْنَاهُمْ فَكَانُوا هُمُ الْغَالِبِينَ"},{"verseKey":"37:117","surah":37,"ayah":117,"text":"وَآتَيْنَاهُمَا الْكِتَابَ الْمُسْتَبِينَ"},{"verseKey":"37:118","surah":37,"ayah":118,"text":"وَهَدَيْنَاهُمَا الصِّرَاطَ الْمُسْتَقِيمَ"},{"verseKey":"37:119","surah":37,"ayah":119,"text":"وَتَرَكْنَا عَلَيْهِمَا فِي الْآخِرِينَ"},{"verseKey":"37:120","surah":37,"ayah":120,"text":"سَلَامٌ عَلَىٰ مُوسَىٰ وَهَارُونَ"},{"verseKey":"37:121","surah":37,"ayah":121,"text":"إِنَّا كَذَٰلِكَ نَجْزِي الْمُحْسِنِينَ"},{"verseKey":"37:122","surah":37,"ayah":122,"text":"إِنَّهُمَا مِنْ عِبَادِنَا الْمُؤْمِنِينَ"},{"verseKey":"37:123","surah":37,"ayah":123,"text":"وَإِنَّ إِلْيَاسَ لَمِنَ الْمُرْسَلِينَ"},{"verseKey":"37:124","surah":37,"ayah":124,"text":"إِذْ قَالَ لِقَوْمِهِ أَلَا تَتَّقُونَ"},{"verseKey":"37:125","surah":37,"ayah":125,"text":"أَتَدْعُونَ بَعْلًا وَتَذَرُونَ أَحْسَنَ الْخَالِقِينَ"},{"verseKey":"37:126","surah":37,"ayah":126,"text":"اللَّهَ رَبَّكُمْ وَرَبَّ آبَائِكُمُ الْأَوَّلِينَ"}]}

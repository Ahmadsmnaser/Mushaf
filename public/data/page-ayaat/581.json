{"pageNumber":581,"ayahs":[{"verseKey":"77:20","surah":77,"ayah":20,"text":"أَلَمْ نَخْلُقْكُمْ مِنْ مَاءٍ مَهِينٍ"},{"verseKey":"77:21","surah":77,"ayah":21,"text":"فَجَعَلْنَاهُ فِي قَرَارٍ مَكِينٍ"},{"verseKey":"77:22","surah":77,"ayah":22,"text":"إِلَىٰ قَدَرٍ مَعْلُومٍ"},{"verseKey":"77:23","surah":77,"ayah":23,"text":"فَقَدَرْنَا فَنِعْمَ الْقَادِرُونَ"},{"verseKey":"77:24","surah":77,"ayah":24,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"77:25","surah":77,"ayah":25,"text":"أَلَمْ نَجْعَلِ الْأَرْضَ كِفَاتًا"},{"verseKey":"77:26","surah":77,"ayah":26,"text":"أَحْيَاءً وَأَمْوَاتًا"},{"verseKey":"77:27","surah":77,"ayah":27,"text":"وَجَعَلْنَا فِيهَا رَوَاسِيَ شَامِخَاتٍ وَأَسْقَيْنَاكُمْ مَاءً فُرَاتًا"},{"verseKey":"77:28","surah":77,"ayah":28,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"77:29","surah":77,"ayah":29,"text":"انْطَلِقُوا إِلَىٰ مَا كُنْتُمْ بِهِ تُكَذِّبُونَ"},{"verseKey":"77:30","surah":77,"ayah":30,"text":"انْطَلِقُوا إِلَىٰ ظِلٍّ ذِي ثَلَاثِ شُعَبٍ"},{"verseKey":"77:31","surah":77,"ayah":31,"text":"لَا ظَلِيلٍ وَلَا يُغْنِي مِنَ اللَّهَبِ"},{"verseKey":"77:32","surah":77,"ayah":32,"text":"إِنَّهَا تَرْمِي بِشَرَرٍ كَالْقَصْرِ"},{"verseKey":"77:33","surah":77,"ayah":33,"text":"كَأَنَّهُ جِمَالَتٌ صُفْرٌ"},{"verseKey":"77:34","surah":77,"ayah":34,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"77:35","surah":77,"ayah":35,"text":"هَٰذَا يَوْمُ لَا يَنْطِقُونَ"},{"verseKey":"77:36","surah":77,"ayah":36,"text":"وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ"},{"verseKey":"77:37","surah":77,"ayah":37,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"77:38","surah":77,"ayah":38,"text":"هَٰذَا يَوْمُ الْفَصْلِ ۖ جَمَعْنَاكُمْ وَالْأَوَّلِينَ"},{"verseKey":"77:39","surah":77,"ayah":39,"text":"فَإِنْ كَانَ لَكُمْ كَيْدٌ فَكِيدُونِ"},{"verseKey":"77:40","surah":77,"ayah":40,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"77:41","surah":77,"ayah":41,"text":"إِنَّ الْمُتَّقِينَ فِي ظِلَالٍ وَعُيُونٍ"},{"verseKey":"77:42","surah":77,"ayah":42,"text":"وَفَوَاكِهَ مِمَّا يَشْتَهُونَ"},{"verseKey":"77:43","surah":77,"ayah":43,"text":"كُلُوا وَاشْرَبُوا هَنِيئًا بِمَا كُنْتُمْ تَعْمَلُونَ"},{"verseKey":"77:44","surah":77,"ayah":44,"text":"إِنَّا كَذَٰلِكَ نَجْزِي الْمُحْسِنِينَ"},{"verseKey":"77:45","surah":77,"ayah":45,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"77:46","surah":77,"ayah":46,"text":"كُلُوا وَتَمَتَّعُوا قَلِيلًا إِنَّكُمْ مُجْرِمُونَ"},{"verseKey":"77:47","surah":77,"ayah":47,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"77:48","surah":77,"ayah":48,"text":"وَإِذَا قِيلَ لَهُمُ ارْكَعُوا لَا يَرْكَعُونَ"},{"verseKey":"77:49","surah":77,"ayah":49,"text":"وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ"},{"verseKey":"77:50","surah":77,"ayah":50,"text":"فَبِأَيِّ حَدِيثٍ بَعْدَهُ يُؤْمِنُونَ"}]}

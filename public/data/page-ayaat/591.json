{"pageNumber":591,"ayahs":[{"verseKey":"86:1","surah":86,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالسَّمَاءِ وَالطَّارِقِ"},{"verseKey":"86:2","surah":86,"ayah":2,"text":"وَمَا أَدْرَاكَ مَا الطَّارِقُ"},{"verseKey":"86:3","surah":86,"ayah":3,"text":"النَّجْمُ الثَّاقِبُ"},{"verseKey":"86:4","surah":86,"ayah":4,"text":"إِنْ كُلُّ نَفْسٍ لَمَّا عَلَيْهَا حَافِظٌ"},{"verseKey":"86:5","surah":86,"ayah":5,"text":"فَلْيَنْظُرِ الْإِنْسَانُ مِمَّ خُلِقَ"},{"verseKey":"86:6","surah":86,"ayah":6,"text":"خُلِقَ مِنْ مَاءٍ دَافِقٍ"},{"verseKey":"86:7","surah":86,"ayah":7,"text":"يَخْرُجُ مِنْ بَيْنِ الصُّلْبِ وَالتَّرَائِبِ"},{"verseKey":"86:8","surah":86,"ayah":8,"text":"إِنَّهُ عَلَىٰ رَجْعِهِ لَقَادِرٌ"},{"verseKey":"86:9","surah":86,"ayah":9,"text":"يَوْمَ تُبْلَى السَّرَائِرُ"},{"verseKey":"86:10","surah":86,"ayah":10,"text":"فَمَا لَهُ مِنْ قُوَّةٍ وَلَا نَاصِرٍ"},{"verseKey":"86:11","surah":86,"ayah":11,"text":"وَالسَّمَاءِ ذَاتِ الرَّجْعِ"},{"verseKey":"86:12","surah":86,"ayah":12,"text":"وَالْأَرْضِ ذَاتِ الصَّدْعِ"},{"verseKey":"86:13","surah":86,"ayah":13,"text":"إِنَّهُ لَقَوْلٌ فَصْلٌ"},{"verseKey":"86:14","surah":86,"ayah":14,"text":"وَمَا هُوَ بِالْهَزْلِ"},{"verseKey":"86:15","surah":86,"ayah":15,"text":"إِنَّهُمْ يَكِيدُونَ كَيْدًا"},{"verseKey":"86:16","surah":86,"ayah":16,"text":"وَأَكِيدُ كَيْدًا"},{"verseKey":"86:17","surah":86,"ayah":17,"text":"فَمَهِّلِ الْكَافِرِينَ أَمْهِلْهُمْ رُوَيْدًا"},{"verseKey":"87:1","surah":87,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى"},{"verseKey":"87:2","surah":87,"ayah":2,"text":"الَّذِي خَلَقَ فَسَوَّىٰ"},{"verseKey":"87:3","surah":87,"ayah":3,"text":"وَالَّذِي قَدَّرَ فَهَدَىٰ"},{"verseKey":"87:4","surah":87,"ayah":4,"text":"وَالَّذِي أَخْرَجَ الْمَرْعَىٰ"},{"verseKey":"87:5","surah":87,"ayah":5,"text":"فَجَعَلَهُ غُثَاءً أَحْوَىٰ"},{"verseKey":"87:6","surah":87,"ayah":6,"text":"سَنُقْرِئُكَ فَلَا تَنْسَىٰ"},{"verseKey":"87:7","surah":87,"ayah":7,"text":"إِلَّا مَا شَاءَ اللَّهُ ۚ إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَىٰ"},{"verseKey":"87:8","surah":87,"ayah":8,"text":"وَنُيَسِّرُكَ لِلْيُسْرَىٰ"},{"verseKey":"87:9","surah":87,"ayah":9,"text":"فَذَكِّرْ إِنْ نَفَعَتِ الذِّكْرَىٰ"},{"verseKey":"87:10","surah":87,"ayah":10,"text":"سَيَذَّكَّرُ مَنْ يَخْشَىٰ"}]}

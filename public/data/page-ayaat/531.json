{"pageNumber":531,"ayahs":[{"verseKey":"54:50","surah":54,"ayah":50,"text":"وَمَا أَمْرُنَا إِلَّا وَاحِدَةٌ كَلَمْحٍ بِالْبَصَرِ"},{"verseKey":"54:51","surah":54,"ayah":51,"text":"وَلَقَدْ أَهْلَكْنَا أَشْيَاعَكُمْ فَهَلْ مِنْ مُدَّكِرٍ"},{"verseKey":"54:52","surah":54,"ayah":52,"text":"وَكُلُّ شَيْءٍ فَعَلُوهُ فِي الزُّبُرِ"},{"verseKey":"54:53","surah":54,"ayah":53,"text":"وَكُلُّ صَغِيرٍ وَكَبِيرٍ مُسْتَطَرٌ"},{"verseKey":"54:54","surah":54,"ayah":54,"text":"إِنَّ الْمُتَّقِينَ فِي جَنَّاتٍ وَنَهَرٍ"},{"verseKey":"54:55","surah":54,"ayah":55,"text":"فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ"},{"verseKey":"55:1","surah":55,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ الرَّحْمَٰنُ"},{"verseKey":"55:2","surah":55,"ayah":2,"text":"عَلَّمَ الْقُرْآنَ"},{"verseKey":"55:3","surah":55,"ayah":3,"text":"خَلَقَ الْإِنْسَانَ"},{"verseKey":"55:4","surah":55,"ayah":4,"text":"عَلَّمَهُ الْبَيَانَ"},{"verseKey":"55:5","surah":55,"ayah":5,"text":"الشَّمْسُ وَالْقَمَرُ بِحُسْبَانٍ"},{"verseKey":"55:6","surah":55,"ayah":6,"text":"وَالنَّجْمُ وَالشَّجَرُ يَسْجُدَانِ"},{"verseKey":"55:7","surah":55,"ayah":7,"text":"وَالسَّمَاءَ رَفَعَهَا وَوَضَعَ الْمِيزَانَ"},{"verseKey":"55:8","surah":55,"ayah":8,"text":"أَلَّا تَطْغَوْا فِي الْمِيزَانِ"},{"verseKey":"55:9","surah":55,"ayah":9,"text":"وَأَقِيمُوا الْوَزْنَ بِالْقِسْطِ وَلَا تُخْسِرُوا الْمِيزَانَ"},{"verseKey":"55:10","surah":55,"ayah":10,"text":"وَالْأَرْضَ وَضَعَهَا لِلْأَنَامِ"},{"verseKey":"55:11","surah":55,"ayah":11,"text":"فِيهَا فَاكِهَةٌ وَالنَّخْلُ ذَاتُ الْأَكْمَامِ"},{"verseKey":"55:12","surah":55,"ayah":12,"text":"وَالْحَبُّ ذُو الْعَصْفِ وَالرَّيْحَانُ"},{"verseKey":"55:13","surah":55,"ayah":13,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:14","surah":55,"ayah":14,"text":"خَلَقَ الْإِنْسَانَ مِنْ صَلْصَالٍ كَالْفَخَّارِ"},{"verseKey":"55:15","surah":55,"ayah":15,"text":"وَخَلَقَ الْجَانَّ مِنْ مَارِجٍ مِنْ نَارٍ"},{"verseKey":"55:16","surah":55,"ayah":16,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"},{"verseKey":"55:17","surah":55,"ayah":17,"text":"رَبُّ الْمَشْرِقَيْنِ وَرَبُّ الْمَغْرِبَيْنِ"},{"verseKey":"55:18","surah":55,"ayah":18,"text":"فَبِأَيِّ آلَاءِ رَبِّكُمَا تُكَذِّبَانِ"}]}

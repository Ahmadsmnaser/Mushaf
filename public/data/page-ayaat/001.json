{"pageNumber":1,"ayahs":[{"verseKey":"1:1","surah":1,"ayah":1,"text":"﻿بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"},{"verseKey":"1:2","surah":1,"ayah":2,"text":"الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ"},{"verseKey":"1:3","surah":1,"ayah":3,"text":"الرَّحْمَٰنِ الرَّحِيمِ"},{"verseKey":"1:4","surah":1,"ayah":4,"text":"مَالِكِ يَوْمِ الدِّينِ"},{"verseKey":"1:5","surah":1,"ayah":5,"text":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ"},{"verseKey":"1:6","surah":1,"ayah":6,"text":"اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ"},{"verseKey":"1:7","surah":1,"ayah":7,"text":"صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ"}]}

{"pageNumber":577,"ayahs":[{"verseKey":"74:48","surah":74,"ayah":48,"text":"فَمَا تَنْفَعُهُمْ شَفَاعَةُ الشَّافِعِينَ"},{"verseKey":"74:49","surah":74,"ayah":49,"text":"فَمَا لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ"},{"verseKey":"74:50","surah":74,"ayah":50,"text":"كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ"},{"verseKey":"74:51","surah":74,"ayah":51,"text":"فَرَّتْ مِنْ قَسْوَرَةٍ"},{"verseKey":"74:52","surah":74,"ayah":52,"text":"بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنْهُمْ أَنْ يُؤْتَىٰ صُحُفًا مُنَشَّرَةً"},{"verseKey":"74:53","surah":74,"ayah":53,"text":"كَلَّا ۖ بَلْ لَا يَخَافُونَ الْآخِرَةَ"},{"verseKey":"74:54","surah":74,"ayah":54,"text":"كَلَّا إِنَّهُ تَذْكِرَةٌ"},{"verseKey":"74:55","surah":74,"ayah":55,"text":"فَمَنْ شَاءَ ذَكَرَهُ"},{"verseKey":"74:56","surah":74,"ayah":56,"text":"وَمَا يَذْكُرُونَ إِلَّا أَنْ يَشَاءَ اللَّهُ ۚ هُوَ أَهْلُ التَّقْوَىٰ وَأَهْلُ الْمَغْفِرَةِ"},{"verseKey":"75:1","surah":75,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ"},{"verseKey":"75:2","surah":75,"ayah":2,"text":"وَلَا أُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِ"},{"verseKey":"75:3","surah":75,"ayah":3,"text":"أَيَحْسَبُ الْإِنْسَانُ أَلَّنْ نَجْمَعَ عِظَامَهُ"},{"verseKey":"75:4","surah":75,"ayah":4,"text":"بَلَىٰ قَادِرِينَ عَلَىٰ أَنْ نُسَوِّيَ بَنَانَهُ"},{"verseKey":"75:5","surah":75,"ayah":5,"text":"بَلْ يُرِيدُ الْإِنْسَانُ لِيَفْجُرَ أَمَامَهُ"},{"verseKey":"75:6","surah":75,"ayah":6,"text":"يَسْأَلُ أَيَّانَ يَوْمُ الْقِيَامَةِ"},{"verseKey":"75:7","surah":75,"ayah":7,"text":"فَإِذَا بَرِقَ الْبَصَرُ"},{"verseKey":"75:8","surah":75,"ayah":8,"text":"وَخَسَفَ الْقَمَرُ"},{"verseKey":"75:9","surah":75,"ayah":9,"text":"وَجُمِعَ الشَّمْسُ وَالْقَمَرُ"},{"verseKey":"75:10","surah":75,"ayah":10,"text":"يَقُولُ الْإِنْسَانُ يَوْمَئِذٍ أَيْنَ الْمَفَرُّ"},{"verseKey":"75:11","surah":75,"ayah":11,"text":"كَلَّا لَا وَزَرَ"},{"verseKey":"75:12","surah":75,"ayah":12,"text":"إِلَىٰ رَبِّكَ يَوْمَئِذٍ الْمُسْتَقَرُّ"},{"verseKey":"75:13","surah":75,"ayah":13,"text":"يُنَبَّأُ الْإِنْسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ"},{"verseKey":"75:14","surah":75,"ayah":14,"text":"بَلِ الْإِنْسَانُ عَلَىٰ نَفْسِهِ بَصِيرَةٌ"},{"verseKey":"75:15","surah":75,"ayah":15,"text":"وَلَوْ أَلْقَىٰ مَعَاذِيرَهُ"},{"verseKey":"75:16","surah":75,"ayah":16,"text":"لَا تُحَرِّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ"},{"verseKey":"75:17","surah":75,"ayah":17,"text":"إِنَّ عَلَيْنَا جَمْعَهُ وَقُرْآنَهُ"},{"verseKey":"75:18","surah":75,"ayah":18,"text":"فَإِذَا قَرَأْنَاهُ فَاتَّبِعْ قُرْآنَهُ"},{"verseKey":"75:19","surah":75,"ayah":19,"text":"ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ"}]}

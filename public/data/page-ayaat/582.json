{"pageNumber":582,"ayahs":[{"verseKey":"78:1","surah":78,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ عَمَّ يَتَسَاءَلُونَ"},{"verseKey":"78:2","surah":78,"ayah":2,"text":"عَنِ النَّبَإِ الْعَظِيمِ"},{"verseKey":"78:3","surah":78,"ayah":3,"text":"الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ"},{"verseKey":"78:4","surah":78,"ayah":4,"text":"كَلَّا سَيَعْلَمُونَ"},{"verseKey":"78:5","surah":78,"ayah":5,"text":"ثُمَّ كَلَّا سَيَعْلَمُونَ"},{"verseKey":"78:6","surah":78,"ayah":6,"text":"أَلَمْ نَجْعَلِ الْأَرْضَ مِهَادًا"},{"verseKey":"78:7","surah":78,"ayah":7,"text":"وَالْجِبَالَ أَوْتَادًا"},{"verseKey":"78:8","surah":78,"ayah":8,"text":"وَخَلَقْنَاكُمْ أَزْوَاجًا"},{"verseKey":"78:9","surah":78,"ayah":9,"text":"وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا"},{"verseKey":"78:10","surah":78,"ayah":10,"text":"وَجَعَلْنَا اللَّيْلَ لِبَاسًا"},{"verseKey":"78:11","surah":78,"ayah":11,"text":"وَجَعَلْنَا النَّهَارَ مَعَاشًا"},{"verseKey":"78:12","surah":78,"ayah":12,"text":"وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا"},{"verseKey":"78:13","surah":78,"ayah":13,"text":"وَجَعَلْنَا سِرَاجًا وَهَّاجًا"},{"verseKey":"78:14","surah":78,"ayah":14,"text":"وَأَنْزَلْنَا مِنَ الْمُعْصِرَاتِ مَاءً ثَجَّاجًا"},{"verseKey":"78:15","surah":78,"ayah":15,"text":"لِنُخْرِجَ بِهِ حَبًّا وَنَبَاتًا"},{"verseKey":"78:16","surah":78,"ayah":16,"text":"وَجَنَّاتٍ أَلْفَافًا"},{"verseKey":"78:17","surah":78,"ayah":17,"text":"إِنَّ يَوْمَ الْفَصْلِ كَانَ مِيقَاتًا"},{"verseKey":"78:18","surah":78,"ayah":18,"text":"يَوْمَ يُنْفَخُ فِي الصُّورِ فَتَأْتُونَ أَفْوَاجًا"},{"verseKey":"78:19","surah":78,"ayah":19,"text":"وَفُتِحَتِ السَّمَاءُ فَكَانَتْ أَبْوَابًا"},{"verseKey":"78:20","surah":78,"ayah":20,"text":"وَسُيِّرَتِ الْجِبَالُ فَكَانَتْ سَرَابًا"},{"verseKey":"78:21","surah":78,"ayah":21,"text":"إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا"},{"verseKey":"78:22","surah":78,"ayah":22,"text":"لِلطَّاغِينَ مَآبًا"},{"verseKey":"78:23","surah":78,"ayah":23,"text":"لَابِثِينَ فِيهَا أَحْقَابًا"},{"verseKey":"78:24","surah":78,"ayah":24,"text":"لَا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا"},{"verseKey":"78:25","surah":78,"ayah":25,"text":"إِلَّا حَمِيمًا وَغَسَّاقًا"},{"verseKey":"78:26","surah":78,"ayah":26,"text":"جَزَاءً وِفَاقًا"},{"verseKey":"78:27","surah":78,"ayah":27,"text":"إِنَّهُمْ كَانُوا لَا يَرْجُونَ حِسَابًا"},{"verseKey":"78:28","surah":78,"ayah":28,"text":"وَكَذَّبُوا بِآيَاتِنَا كِذَّابًا"},{"verseKey":"78:29","surah":78,"ayah":29,"text":"وَكُلَّ شَيْءٍ أَحْصَيْنَاهُ كِتَابًا"},{"verseKey":"78:30","surah":78,"ayah":30,"text":"فَذُوقُوا فَلَنْ نَزِيدَكُمْ إِلَّا عَذَابًا"}]}

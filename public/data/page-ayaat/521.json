{"pageNumber":521,"ayahs":[{"verseKey":"51:7","surah":51,"ayah":7,"text":"وَالسَّمَاءِ ذَاتِ الْحُبُكِ"},{"verseKey":"51:8","surah":51,"ayah":8,"text":"إِنَّكُمْ لَفِي قَوْلٍ مُخْتَلِفٍ"},{"verseKey":"51:9","surah":51,"ayah":9,"text":"يُؤْفَكُ عَنْهُ مَنْ أُفِكَ"},{"verseKey":"51:10","surah":51,"ayah":10,"text":"قُتِلَ الْخَرَّاصُونَ"},{"verseKey":"51:11","surah":51,"ayah":11,"text":"الَّذِينَ هُمْ فِي غَمْرَةٍ سَاهُونَ"},{"verseKey":"51:12","surah":51,"ayah":12,"text":"يَسْأَلُونَ أَيَّانَ يَوْمُ الدِّينِ"},{"verseKey":"51:13","surah":51,"ayah":13,"text":"يَوْمَ هُمْ عَلَى النَّارِ يُفْتَنُونَ"},{"verseKey":"51:14","surah":51,"ayah":14,"text":"ذُوقُوا فِتْنَتَكُمْ هَٰذَا الَّذِي كُنْتُمْ بِهِ تَسْتَعْجِلُونَ"},{"verseKey":"51:15","surah":51,"ayah":15,"text":"إِنَّ الْمُتَّقِينَ فِي جَنَّاتٍ وَعُيُونٍ"},{"verseKey":"51:16","surah":51,"ayah":16,"text":"آخِذِينَ مَا آتَاهُمْ رَبُّهُمْ ۚ إِنَّهُمْ كَانُوا قَبْلَ ذَٰلِكَ مُحْسِنِينَ"},{"verseKey":"51:17","surah":51,"ayah":17,"text":"كَانُوا قَلِيلًا مِنَ اللَّيْلِ مَا يَهْجَعُونَ"},{"verseKey":"51:18","surah":51,"ayah":18,"text":"وَبِالْأَسْحَارِ هُمْ يَسْتَغْفِرُونَ"},{"verseKey":"51:19","surah":51,"ayah":19,"text":"وَفِي أَمْوَالِهِمْ حَقٌّ لِلسَّائِلِ وَالْمَحْرُومِ"},{"verseKey":"51:20","surah":51,"ayah":20,"text":"وَفِي الْأَرْضِ آيَاتٌ لِلْمُوقِنِينَ"},{"verseKey":"51:21","surah":51,"ayah":21,"text":"وَفِي أَنْفُسِكُمْ ۚ أَفَلَا تُبْصِرُونَ"},{"verseKey":"51:22","surah":51,"ayah":22,"text":"وَفِي السَّمَاءِ رِزْقُكُمْ وَمَا تُوعَدُونَ"},{"verseKey":"51:23","surah":51,"ayah":23,"text":"فَوَرَبِّ السَّمَاءِ وَالْأَرْضِ إِنَّهُ لَحَقٌّ مِثْلَ مَا أَنَّكُمْ تَنْطِقُونَ"},{"verseKey":"51:24","surah":51,"ayah":24,"text":"هَلْ أَتَاكَ حَدِيثُ ضَيْفِ إِبْرَاهِيمَ الْمُكْرَمِينَ"},{"verseKey":"51:25","surah":51,"ayah":25,"text":"إِذْ دَخَلُوا عَلَيْهِ فَقَالُوا سَلَامًا ۖ قَالَ سَلَامٌ قَوْمٌ مُنْكَرُونَ"},{"verseKey":"51:26","surah":51,"ayah":26,"text":"فَرَاغَ إِلَىٰ أَهْلِهِ فَجَاءَ بِعِجْلٍ سَمِينٍ"},{"verseKey":"51:27","surah":51,"ayah":27,"text":"فَقَرَّبَهُ إِلَيْهِمْ قَالَ أَلَا تَأْكُلُونَ"},{"verseKey":"51:28","surah":51,"ayah":28,"text":"فَأَوْجَسَ مِنْهُمْ خِيفَةً ۖ قَالُوا لَا تَخَفْ ۖ وَبَشَّرُوهُ بِغُلَامٍ عَلِيمٍ"},{"verseKey":"51:29","surah":51,"ayah":29,"text":"فَأَقْبَلَتِ امْرَأَتُهُ فِي صَرَّةٍ فَصَكَّتْ وَجْهَهَا وَقَالَتْ عَجُوزٌ عَقِيمٌ"},{"verseKey":"51:30","surah":51,"ayah":30,"text":"قَالُوا كَذَٰلِكِ قَالَ رَبُّكِ ۖ إِنَّهُ هُوَ الْحَكِيمُ الْعَلِيمُ"}]}

{"pageNumber":313,"ayahs":[{"verseKey":"20:13","surah":20,"ayah":13,"text":"وَأَنَا اخْتَرْتُكَ فَاسْتَمِعْ لِمَا يُوحَىٰ"},{"verseKey":"20:14","surah":20,"ayah":14,"text":"إِنَّنِي أَنَا اللَّهُ لَا إِلَٰهَ إِلَّا أَنَا فَاعْبُدْنِي وَأَقِمِ الصَّلَاةَ لِذِكْرِي"},{"verseKey":"20:15","surah":20,"ayah":15,"text":"إِنَّ السَّاعَةَ آتِيَةٌ أَكَادُ أُخْفِيهَا لِتُجْزَىٰ كُلُّ نَفْسٍ بِمَا تَسْعَىٰ"},{"verseKey":"20:16","surah":20,"ayah":16,"text":"فَلَا يَصُدَّنَّكَ عَنْهَا مَنْ لَا يُؤْمِنُ بِهَا وَاتَّبَعَ هَوَاهُ فَتَرْدَىٰ"},{"verseKey":"20:17","surah":20,"ayah":17,"text":"وَمَا تِلْكَ بِيَمِينِكَ يَا مُوسَىٰ"},{"verseKey":"20:18","surah":20,"ayah":18,"text":"قَالَ هِيَ عَصَايَ أَتَوَكَّأُ عَلَيْهَا وَأَهُشُّ بِهَا عَلَىٰ غَنَمِي وَلِيَ فِيهَا مَآرِبُ أُخْرَىٰ"},{"verseKey":"20:19","surah":20,"ayah":19,"text":"قَالَ أَلْقِهَا يَا مُوسَىٰ"},{"verseKey":"20:20","surah":20,"ayah":20,"text":"فَأَلْقَاهَا فَإِذَا هِيَ حَيَّةٌ تَسْعَىٰ"},{"verseKey":"20:21","surah":20,"ayah":21,"text":"قَالَ خُذْهَا وَلَا تَخَفْ ۖ سَنُعِيدُهَا سِيرَتَهَا الْأُولَىٰ"},{"verseKey":"20:22","surah":20,"ayah":22,"text":"وَاضْمُمْ يَدَكَ إِلَىٰ جَنَاحِكَ تَخْرُجْ بَيْضَاءَ مِنْ غَيْرِ سُوءٍ آيَةً أُخْرَىٰ"},{"verseKey":"20:23","surah":20,"ayah":23,"text":"لِنُرِيَكَ مِنْ آيَاتِنَا الْكُبْرَى"},{"verseKey":"20:24","surah":20,"ayah":24,"text":"اذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُ طَغَىٰ"},{"verseKey":"20:25","surah":20,"ayah":25,"text":"قَالَ رَبِّ اشْرَحْ لِي صَدْرِي"},{"verseKey":"20:26","surah":20,"ayah":26,"text":"وَيَسِّرْ لِي أَمْرِي"},{"verseKey":"20:27","surah":20,"ayah":27,"text":"وَاحْلُلْ عُقْدَةً مِنْ لِسَانِي"},{"verseKey":"20:28","surah":20,"ayah":28,"text":"يَفْقَهُوا قَوْلِي"},{"verseKey":"20:29","surah":20,"ayah":29,"text":"وَاجْعَلْ لِي وَزِيرًا مِنْ أَهْلِي"},{"verseKey":"20:30","surah":20,"ayah":30,"text":"هَارُونَ أَخِي"},{"verseKey":"20:31","surah":20,"ayah":31,"text":"اشْدُدْ بِهِ أَزْرِي"},{"verseKey":"20:32","surah":20,"ayah":32,"text":"وَأَشْرِكْهُ فِي أَمْرِي"},{"verseKey":"20:33","surah":20,"ayah":33,"text":"كَيْ نُسَبِّحَكَ كَثِيرًا"},{"verseKey":"20:34","surah":20,"ayah":34,"text":"وَنَذْكُرَكَ كَثِيرًا"},{"verseKey":"20:35","surah":20,"ayah":35,"text":"إِنَّكَ كُنْتَ بِنَا بَصِيرًا"},{"verseKey":"20:36","surah":20,"ayah":36,"text":"قَالَ قَدْ أُوتِيتَ سُؤْلَكَ يَا مُوسَىٰ"},{"verseKey":"20:37","surah":20,"ayah":37,"text":"وَلَقَدْ مَنَنَّا عَلَيْكَ مَرَّةً أُخْرَىٰ"}]}

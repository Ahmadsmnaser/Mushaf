{"pageNumber":370,"ayahs":[{"verseKey":"26:61","surah":26,"ayah":61,"text":"فَلَمَّا تَرَاءَى الْجَمْعَانِ قَالَ أَصْحَابُ مُوسَىٰ إِنَّا لَمُدْرَكُونَ"},{"verseKey":"26:62","surah":26,"ayah":62,"text":"قَالَ كَلَّا ۖ إِنَّ مَعِيَ رَبِّي سَيَهْدِينِ"},{"verseKey":"26:63","surah":26,"ayah":63,"text":"فَأَوْحَيْنَا إِلَىٰ مُوسَىٰ أَنِ اضْرِبْ بِعَصَاكَ الْبَحْرَ ۖ فَانْفَلَقَ فَكَانَ كُلُّ فِرْقٍ كَالطَّوْدِ الْعَظِيمِ"},{"verseKey":"26:64","surah":26,"ayah":64,"text":"وَأَزْلَفْنَا ثَمَّ الْآخَرِينَ"},{"verseKey":"26:65","surah":26,"ayah":65,"text":"وَأَنْجَيْنَا مُوسَىٰ وَمَنْ مَعَهُ أَجْمَعِينَ"},{"verseKey":"26:66","surah":26,"ayah":66,"text":"ثُمَّ أَغْرَقْنَا الْآخَرِينَ"},{"verseKey":"26:67","surah":26,"ayah":67,"text":"إِنَّ فِي ذَٰلِكَ لَآيَةً ۖ وَمَا كَانَ أَكْثَرُهُمْ مُؤْمِنِينَ"},{"verseKey":"26:68","surah":26,"ayah":68,"text":"وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ الرَّحِيمُ"},{"verseKey":"26:69","surah":26,"ayah":69,"text":"وَاتْلُ عَلَيْهِمْ نَبَأَ إِبْرَاهِيمَ"},{"verseKey":"26:70","surah":26,"ayah":70,"text":"إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِ مَا تَعْبُدُونَ"},{"verseKey":"26:71","surah":26,"ayah":71,"text":"قَالُوا نَعْبُدُ أَصْنَامًا فَنَظَلُّ لَهَا عَاكِفِينَ"},{"verseKey":"26:72","surah":26,"ayah":72,"text":"قَالَ هَلْ يَسْمَعُونَكُمْ إِذْ تَدْعُونَ"},{"verseKey":"26:73","surah":26,"ayah":73,"text":"أَوْ يَنْفَعُونَكُمْ أَوْ يَضُرُّونَ"},{"verseKey":"26:74","surah":26,"ayah":74,"text":"قَالُوا بَلْ وَجَدْنَا آبَاءَنَا كَذَٰلِكَ يَفْعَلُونَ"},{"verseKey":"26:75","surah":26,"ayah":75,"text":"قَالَ أَفَرَأَيْتُمْ مَا كُنْتُمْ تَعْبُدُونَ"},{"verseKey":"26:76","surah":26,"ayah":76,"text":"أَنْتُمْ وَآبَاؤُكُمُ الْأَقْدَمُونَ"},{"verseKey":"26:77","surah":26,"ayah":77,"text":"فَإِنَّهُمْ عَدُوٌّ لِي إِلَّا رَبَّ الْعَالَمِينَ"},{"verseKey":"26:78","surah":26,"ayah":78,"text":"الَّذِي خَلَقَنِي فَهُوَ يَهْدِينِ"},{"verseKey":"26:79","surah":26,"ayah":79,"text":"وَالَّذِي هُوَ يُطْعِمُنِي وَيَسْقِينِ"},{"verseKey":"26:80","surah":26,"ayah":80,"text":"وَإِذَا مَرِضْتُ فَهُوَ يَشْفِينِ"},{"verseKey":"26:81","surah":26,"ayah":81,"text":"وَالَّذِي يُمِيتُنِي ثُمَّ يُحْيِينِ"},{"verseKey":"26:82","surah":26,"ayah":82,"text":"وَالَّذِي أَطْمَعُ أَنْ يَغْفِرَ لِي خَطِيئَتِي يَوْمَ الدِّينِ"},{"verseKey":"26:83","surah":26,"ayah":83,"text":"رَبِّ هَبْ لِي حُكْمًا وَأَلْحِقْنِي بِالصَّالِحِينَ"}]}

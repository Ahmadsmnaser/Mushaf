# Tafsir source credentials — read ONLY by the server route (app/api/tafsir/*
# via lib/tafsir/server.ts). No NEXT_PUBLIC_ prefix here, ever: these must
# never reach the client bundle. Copy to .env.local and fill in.

# «المختصر في التفسير» — official API of مركز تفسير للدراسات القرآنية.
# Register for a token at https://mokhtasr.com/ar/api-doc
# (POST /app/register, then POST /app/login returns the Bearer token).
# While unset, the source is reported as unavailable and the reader falls
# back to التفسير الميسر, which needs no token.
MOKHTASAR_API_TOKEN=

# The id of «المختصر (آية وتفسير)-عربي» in the mokhtasr.com catalogue
# (confirmed via GET https://admin.mokhtasr.com/api/v1/books).
MOKHTASAR_BOOK_ID=200

# Reserved for the Quran Foundation OAuth API (apis.quran.foundation) —
# not used yet; التفسير الميسر is currently served from the public
# api.quran.com v4 endpoint, which needs no credentials.
QURAN_FOUNDATION_CLIENT_ID=
QURAN_FOUNDATION_CLIENT_SECRET=
